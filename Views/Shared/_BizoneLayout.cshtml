    <!-- Place this tag in your head or just before your close body tag. -->
    <script async defer src="https://buttons.github.io/buttons.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            let username = $("#username").val();
            if (username == "") {
    alert("Session has been expired!");
    window.location.href = '@Url.Action("Login", "Authentication", new { area = "BizOneUsers" })';
}
            // Handle menu clicks
            $(".menu-inner .menu-item > .menu-link").on("click", function (e) {
                var href = $(this).attr("href");

                // Only prevent default if dummy link
                if (href === "#" || href === "") {
                    e.preventDefault();

                    // If it's dummy → still mark as active
                    $(".menu-inner .menu-item").removeClass("active");
                    $(".menu-inner .menu-item .menu-icon").css("color", "");
                    $(this).closest(".menu-item").addClass("active");
                    $(this).find(".menu-icon").css("color", "#fff");
                }
                // ⚠️ If href has a real URL → let browser navigate normally,
                // no need to touch active state here, next page load will highlight it
            });

            // On page load → highlight active menu item based on URL
            var currentPath = window.location.pathname.toLowerCase();

            $(".menu-inner .menu-item > .menu-link").each(function () {
                var linkPath = $(this).attr("href").toLowerCase();

                if (linkPath !== "#" && linkPath !== "" && currentPath.startsWith(linkPath)) {
                    $(".menu-inner .menu-item").removeClass("active");
                    $(".menu-inner .menu-item .menu-icon").css("color", "");
                    $(this).closest(".menu-item").addClass("active");
                    $(this).find(".menu-icon").css("color", "#fff");
                }
            });
        });

    </script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://unpkg.com/filepond/dist/filepond.js"></script>
    @RenderSection("scripts", required: false)
