
@{
    ViewBag.Title = "Cart";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}

<div class="untree_co-section before-footer-section">
    <div class="container">
        <div class="row mb-5">
            <form class="col-md-12" method="post">
                <div class="site-blocks-table">
                    <table class="table" id="cartItems">
                        <thead>
                            <tr>
                                <th class="product-thumbnail">Image</th>
                                <th class="product-name">Product</th>
                                <th class="product-price">Price</th>
                                <th class="product-quantity">Quantity</th>
                                <th class="product-total">Total</th>
                                <th class="product-remove">Remove</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </form>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="row mb-5">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <button class="btn btn-black btn-sm btn-block">Update Cart</button>
                    </div>
                    <div class="col-md-6">
                        <button class="btn btn-outline-black btn-sm btn-block">Continue Shopping</button>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <label class="text-black h4" for="coupon">Coupon</label>
                        <p>Enter your coupon code if you have one.</p>
                    </div>
                    <div class="col-md-8 mb-3 mb-md-0">
                        <input type="text" class="form-control py-3" id="coupon" placeholder="Coupon Code">
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-black" id="varifyCoupen">Apply Coupon</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6 pl-5">
                <div class="row justify-content-end">
                    <div class="col-md-7">
                        <div class="row">
                            <div class="col-md-12 text-right border-bottom mb-5">
                                <h3 class="text-black h4 text-uppercase">Cart Totals</h3>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <span class="text-black">Subtotal</span>
                            </div>
                            <div class="col-md-6 text-right">
                                <strong class="text-black">$230.00</strong>
                            </div>
                        </div>
                        <div class="row mb-5">
                            <div class="col-md-6">
                                <span class="text-black">Total</span>
                            </div>
                            <div class="col-md-6 text-right">
                                <strong class="text-black">$230.00</strong>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <button class="btn btn-black btn-lg py-3 btn-block" onclick="proceedToCheckout()">Proceed To Checkout</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        let currentSymbol = "Rs."; // Global variable for the cart

        $(document).ready(function () {
            loadCart();
        });

        function loadCart() {
            $.ajax({
                url: '@Url.Action("GetCartItems", "Cart", new { area = "EndUser" })',
                type: 'GET',
                success: function (response) {
                    if (response.success) {
                        currentSymbol = response.symbol; // Update symbol from server
                        renderCartTable(response.data);
                        updateTotals(response.subtotal);
                    }
                }
            });
        }

        function renderCartTable(items) {
            const tbody = $('#cartItems tbody');
            tbody.empty();

            if (items.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center py-5">Your cart is empty.</td></tr>');
                return;
            }

            items.forEach(item => {
                const imageSrc = item.ImagePath
                    ? `/Products/Shop/GetImg?path=${encodeURIComponent(item.ImagePath)}`
                    : '/FurniAssets/images/product-1.png';

                // Use the variant info if it exists
                const nameDisplay = item.VariantDetails
                    ? `${item.Name} <br><small class="text-muted">${item.VariantDetails}</small>`
                    : item.Name;

                const row = `
                    <tr>
                        <td class="product-thumbnail">
                            <img src="${imageSrc}" alt="Image" class="img-fluid" style="max-height: 80px; object-fit: contain;">
                        </td>
                        <td class="product-name">
                            <h2 class="h5 text-black">${nameDisplay}</h2>
                        </td>
                        <td>${currentSymbol} ${item.Price.toFixed(2)}</td>
                        <td>
                            <div class="input-group mb-3 d-flex align-items-center quantity-container" style="max-width: 120px;">
                                <div class="input-group-prepend">
                                    <button class="btn btn-outline-black decrease" type="button" onclick="changeQty(${item.ProductId}, ${item.VariantId || 0}, -1)">&minus;</button>
                                </div>
                                <input type="text" id="qty-${item.ProductId}-${item.VariantId || 0}"
                                       class="form-control text-center quantity-amount"
                                       value="${item.Quantity}"
                                       data-stock="${item.ActualStockQuantity}" readonly>
                                <div class="input-group-append">
                                    <button class="btn btn-outline-black increase" type="button" onclick="changeQty(${item.ProductId}, ${item.VariantId || 0}, 1)">&plus;</button>
                                </div>
                            </div>
                        </td>
                        <td>${currentSymbol} ${item.Total.toFixed(2)}</td>
                        <td><a href="javascript:void(0)" onclick="removeItem(${item.ProductId}, ${item.VariantId || 0})" class="btn btn-black btn-sm">X</a></td>
                    </tr>`;
                tbody.append(row);
            });
        }

        function updateTotals(subtotal) {
            // Update all total spans with the correct symbol and amount
            $('.text-right strong.text-black, #cart-subtotal').text(currentSymbol + ' ' + subtotal.toFixed(2));
        }

        function changeQty(productId, variantId, change) {
            // Fixed ID selector to include variantId
            const input = $(`#qty-${productId}-${variantId}`);
            const currentQty = parseInt(input.val());
            const maxStock = parseInt(input.data('stock'));

            if (change > 0 && currentQty >= maxStock) {
                alert(`Only ${maxStock} items available in stock.`);
                return;
            }
            if (change < 0 && currentQty <= 1) {
                removeItem(productId, variantId);
                return;
            }

            $.ajax({
                url: '@Url.Action("UpdateQuantity", "Cart", new { area = "EndUser" })',
                type: 'POST',
                data: { id: productId, VariantId: variantId, change: change },
                success: function (response) {
                    if (response.success) {
                        loadCart();
                        updateBadge();
                    }
                }
            });
        }

        function removeItem(productId, variantId) {
            if (confirm("Are you sure you want to remove this item?")) {
                $.ajax({
                    url: '@Url.Action("RemoveFromCart", "Cart", new { area = "EndUser" })',
                    type: 'POST',
                    data: { id: productId, VariantId: variantId },
                    success: function (response) {
                        if (response.success) {
                            loadCart();
                            updateBadge();
                        }
                    }
                });
            }
        }

        function updateBadge() {
            $.get('@Url.Action("GetCartCount", "Cart", new { area = "EndUser" })', function(data) {
                const badge = $('#cart-badge');
                badge.text(data.count);
                data.count > 0 ? badge.show() : badge.hide();
            });
        }

         function proceedToCheckout() {
    $.ajax({
        url: '@Url.Action("PrepareCheckout", "Checkout", new { area = "EndUser" })',
        type: 'POST',
        success: function (response) {
            if (response.success) {
                window.location.href = response.redirectUrl;
            }
        }
    });
        }

        $('#varifyCoupen').click(function () {
    const code = $('#coupon').val();
    if (!code) {
        alert("Please enter a code");
        return;
    }

    $.ajax({
        url: "@Url.Action("VarifyCouponCode", "Coupens")",
        type: "GET",
        data: { code: code },
        success: function (res) {
            if (res.success) {
                Swal.fire({
                    title: 'Coupon Valid!',
                    text: res.message,
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonText: 'Continue',
                    cancelButtonText: 'Cancel',
                    confirmButtonColor: '#000'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Apply discount to the total in your UI
                        applyDiscountToTotal(res.discount);
                    } else {
                        $('#coupon').val(''); // Reset if cancelled
                    }
                });
            } else {
                Swal.fire('Error', res.message, 'error');
            }
        }
    });
});
    </script>
}