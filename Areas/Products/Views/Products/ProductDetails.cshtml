// 1. Function to open Edit Modal
function editProduct(productId) {
    $.ajax({
        url: '@Url.Action("ReadProductDetailsfromSession", "Products", new { area = "Products"})',
        type: 'GET',
        success: function (res) {
            if (res && res.product) {
                let p = res.product;
                let mappingIds = res.categories.map(c => c.ProductCategoryId).join(',');
                // Set Header
                $("#modalHeaderTitle").text("Edit Product: " + p.Name);

                let bodyHtml = `
                    <form id="editProductForm">
                        <input type="hidden" name="Id" value="${p.Id}" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Product Name</label>
                                <input type="text" name="Name" class="form-control" value="${p.Name}" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">SKU</label>
                                <input type="text" name="SKU" class="form-control" value="${p.SKU}" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Price</label>
                                <input type="number" name="Price" class="form-control" value="${p.Price}" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Stock Quantity</label>
                                <input type="number" name="StockQuantity" class="form-control" value="${p.StockQuantity}" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Discount Rate (%)</label>
                                <input type="number" name="DiscountRate" class="form-control" value="${p.DiscountRate}" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea name="Description" class="form-control" rows="3">${p.Description}</textarea>
                            </div>

                            <div class="col-12 mt-3">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" name="IsAvailable" id="editIsAvailable" ${p.IsAvailable ? 'checked' : ''}>
                                    <label class="form-check-label" for="editIsAvailable">Available</label>
                                </div>

                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" name="OnSale" id="editOnSale" ${p.OnSale ? 'checked' : ''}>
                                    <label class="form-check-label" for="editOnSale">On Sale</label>
                                </div>
                            </div>
                        </div>

                    </form>
                `;

                $("#modalBodyContent").html(bodyHtml);

                let footerHtml = `
                    <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
                        <i class="fa-solid fa-xmark me-1"></i> Close
                    </button>
                    <button type="button" class="btn btn-primary" onclick="updateProduct()">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Save Changes
                    </button>`;
                $("#modalFooterContent").html(footerHtml);
                $("#genericModal").modal('show');
            }
        }
    });
}
