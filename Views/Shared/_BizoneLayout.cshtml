                   $('#chatTitle').html(`
        <div class="d-flex align-items-center">
            <div onclick="backToRooms()" style="cursor:pointer;" class="me-2 text-secondary">
                <i class="bi bi-arrow-left fs-5"></i>
            </div>
            <h6 class="mb-0 fw-bold">Select Users</h6>
        </div>
    `);

                   loadIndividualUsers();
