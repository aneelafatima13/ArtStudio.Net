@section scripts{
    <script>
             $("#formAuthentication").on("submit", function (e) {
    e.preventDefault();

    // ---------- GET VALUES ----------
    let firstName = $("#firstName").val().trim();
    let lastName = $("#lastName").val().trim();
    let fullName = $("#fullName").val().trim();
    let username = $("#newusername").val().trim();
    let password = $("#password").val().trim();
    let roleId = $("#myrolesList").val();
    let departmentId = $("#departmentsList").val();

    // ---------- VALIDATIONS ----------
    if (!firstName) {
        alert("First Name is required");
        return;
    }

    if (!lastName) {
        alert("Last Name is required");
        return;
    }

    if (!fullName) {
        alert("Full Name is required");
        return;
    }

    if (!username) {
        alert("Username is required");
        return;
    }

    if (!password) {
        alert("Password is required");
        return;
    }

    if (!roleId) {
        alert("Please select a Role");
        return;
    }

    if (!departmentId) {
        alert("Please select a Department");
        return;
    }

    // ---------- MODEL ----------
    let model = {
        FirstName: firstName,
        LastName: lastName,
        FullName: fullName,
        FatherName: $("#fatherName").val(),
        CNIC: $("#cnic").val(),
        DateOfBirth: $("#dob").val(),
        Age: $("#age").val(),
        Religion: $("#religion").val(),
        Nationality: $("#nationality").val(),
        Gender: $("input[name='gender']:checked").val(),
        MaritalStatus: $("input[name='maritalStatus']:checked").val(),
        PhoneNo: $("#phone1").val(),
        PhoneNo2: $("#phone2").val(),
        Email: $("#email1").val(),
        Email2: $("#email2").val(),
        Address: $("#address").val(),
        Provence: $("#provence").val(),
        City: $("#city").val(),
        Country: $("#country").val(),
        Username: username,
        Password: password,
        RoleId: roleId,
        RoleName: $("#myrolesList option:selected").text(),
        RoleIdsUnderMe: ($("#rolesListunderme").val() || []).join(","),
        DepartmentId: departmentId,
        DepartmentName: $("#departmentsList option:selected").text(),
        Designation: $("#designation").val(),
        JoiningDate: $("#joiningDate").val(),
        Salary: $("#salary").val(),
        Status: $("input[name='status']:checked").next('label').text(),
        Shift: $("input[name='shift']:checked").next('label').text(),
        ShiftTimmingsId: $("#shiftTimmingsList").val(),
        ShiftTimmings: $("#shiftTimmingsList option:selected").val(),
        IsActive: $("#isactive").is(":checked"),
        Files: []
    };

    let filePromises = [];

    $("input[type=file][name=files]").each(function () {
        let title = $(this).data("title");
        let files = $(this)[0].files;

        for (let i = 0; i < files.length; i++) {
            let file = files[i];

            let promise = new Promise((resolve) => {
                let reader = new FileReader();
                reader.onload = function (e) {
                    let base64String = e.target.result.split(',')[1];

                    model.Files.push({
                        FileName: file.name,
                        FileTitle: title,
                        FileType: file.type,
                        FileBytes: base64String
                    });

                    resolve();
                };
                reader.readAsDataURL(file);
            });

            filePromises.push(promise);
        }
    });

    Promise.all(filePromises).then(function () {
        $.ajax({
            url: '@Url.Action("ManageEmployee", "Employees", new { area = "EMS" })',
            type: 'POST',
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(model),
            success: function (res) {
                if (res.success) {
                    alert("Employee saved with ID: " + res.EmployeeId);
                    location.reload();
                } else {
                    alert("Error: " + res.message);
                }
            },
            error: function () {
                alert("Error while adding employee.");
            }
        });
    });

});

