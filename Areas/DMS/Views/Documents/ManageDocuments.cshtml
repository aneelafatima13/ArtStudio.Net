          function getBreadcrumbHierarchy() {
              let ids = [];
              let names = [];

              $("#empFolders .breadcrumb-item a").each(function () {
                  debugger;
                  let id = $(this).data("id");
                  let name = $(this).text().trim();

                  if (id !== undefined) {
                      ids.push(id);
                      names.push(name);
                  }
              });

              return { ids, names };
          }

    // Upload button handler
    $("#btn-upload-files").on("click", function () {
    if (pond.getFiles().length === 0) {
        alert("Please select files first.");
        return;
    }

    // get breadcrumb
    let breadcrumb = getBreadcrumbHierarchy();
    let folderIds = breadcrumb.ids.join(",");     // e.g. "0,2,4,6"
    let folderNames = breadcrumb.names.join(","); // e.g. "Root,Folder1,Folder2"
        let lastCrumb = $("#empFolders .breadcrumb-item:last a");
        let docFolderId = 0;

        if (lastCrumb.text().trim() !== "Root") {
            docFolderId = lastCrumb.data("id");  // if not Root, take last breadcrumb id
        }

        debugger;
    let formData = new FormData();
    pond.getFiles().forEach((file) => {
        formData.append("files", file.file);
    });

    formData.append("FolderIds", folderIds);
        formData.append("FolderNames", folderNames);
        formData.append("docFolderId", docFolderId);

    $.ajax({
        url: '@Url.Action("UploadDocuments", "Documents", new { area = "DMS" })',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function (res) {
            alert("Files uploaded successfully!");
            $("#selectedFiles").modal("hide");
            pond.removeFiles();
            loadDocuments(docFolderId, 1);
        },
        error: function (err) {
            alert("Error uploading files.");
        }
    });
});

