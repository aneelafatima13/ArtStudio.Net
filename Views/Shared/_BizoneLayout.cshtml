@using BizOne.Common;
@using BizOne.Models;
<!DOCTYPE html>

<html lang="en"
      class="light-style layout-menu-fixed layout-compact"
      dir="ltr"
      data-theme="theme-default"
      data-assets-path="@Url.Content("~/BizOneAssets/")"
      data-template="vertical-menu-template-free">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>BizOne</title>

    <meta name="description" content="" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/BizOneAssets/img/favicon/favicon.ico")" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&ampdisplay=swap"
          rel="stylesheet" />

    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/vendor/fonts/materialdesignicons.css")" />

    <!-- Menu waves for no-customizer fix -->
    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/vendor/libs/node-waves/node-waves.css")" />

    <!-- Core CSS -->
    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/vendor/css/core.css")" class="template-customizer-core-css" />
    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/vendor/css/theme-default.css")" class="template-customizer-theme-css" />
    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/css/demo.css")" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css")" />
    <link rel="stylesheet" href="@Url.Content("~/BizOneAssets/vendor/libs/apex-charts/apex-charts.css")" />

    <script src="@Url.Content("~/BizOneAssets/vendor/js/helpers.js")"></script>

    <script src="@Url.Content("~/BizOneAssets/js/config.js")"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link href="https://unpkg.com/filepond/dist/filepond.css" rel="stylesheet">
    <link href="@Url.Content("~/BizOneAssets/vendor/css/svgcss.css")" rel="stylesheet" />
</head>

<body>

    @{
        string username = LoginUser.EmpUsername;
        string role = LoginUser.EmpRole;

    }
    <input type="hidden" id="username" value="@username" />
    <!-- Layout wrapper -->
    <div class="layout-wrapper layout-content-navbar">

        <div class="layout-container">
            <!-- Menu -->

            <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
                <div class="app-brand demo">
                    <a href="index.html" class="app-brand-link">
                        <span class="app-brand-logo demo me-1">

                        </span>
                        <span class="app-brand-text demo menu-text fw-semibold ms-2">BIZONE</span>
                    </a>

                    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
                        <i class="mdi menu-toggle-icon d-xl-block align-middle mdi-20px"></i>
                    </a>
                </div>
                <div class="menu-inner-shadow"></div>

                <ul class="menu-inner py-1">
                    <!-- Dashboards -->
                    <li class="menu-item"
                        data-bs-toggle="tooltip"
                        data-bs-placement="right"
                        title="Dashboard">
                        <a href="@Url.Action("Dashboard", "Authentication", new { area = "BizOneUsers" })" class="menu-link">
                            <i class="menu-icon tf-icons mdi mdi-home-outline"></i>
                            <div data-i18n="dashboard">Dashboard</div>
                        </a>
                    </li>
                    <li class="menu-item"
                        data-bs-toggle="tooltip"
                        data-bs-placement="right"
                        title="Dashboard">
                        <a href="@Url.Action("Chats", "Chats", new { area = "Admin" })" class="menu-link">
                            <i class="menu-icon tf-icons mdi mdi-message-alert-outline"></i>
                            <div data-i18n="chats">Chats</div>
                        </a>
                    </li>
                    <li class="menu-item"
                        data-bs-toggle="tooltip"
                        data-bs-placement="right"
                        title="Dashboard">
                        <a href="@Url.Action("Reports", "Reports", new { area = "Reports" })" class="menu-link">
                            <i class="menu-icon tf-icons mdi mdi-file-account-outline"></i>
                            
                            <div data-i18n="Reports">Reports</div>
                        </a>
                    </li>


                    @if (role == "Admin" || LoginUser.Rights.PRODUCT_ADD)
                    {
                        <li class="menu-header fw-medium mt-4">
                            <span class="menu-header-text">Products Controls</span>
                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Rights">
                            <a href="@Url.Action("ManageProducts", "Products", new { area = "Products" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-package-check"></i>
                                <div>Manage Products</div>
                            </a>

                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Rights">
                            <a href="@Url.Action("ExchangeRateForms", "Products", new { area = "Products" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-currency-bdt"></i>
                                <div>Manage Exchange Rates</div>
                            </a>

                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Rights">
                            <a href="@Url.Action("ManageCoupens", "Coupens", new { area = "Products" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-counter"></i>
                                <div>Manage Coupens</div>
                            </a>

                        </li>
                    }
                    @if (role == "Admin" || LoginUser.Rights.CATEGORY_MANAGE)
                    {
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Categories">
                            <a href="@Url.Action("ManageCategories", "Categories", new { area = "Products" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-shape-outline"></i>
                                <div>Manage Categories</div>
                            </a>
                        </li>
                    }
                    @if (role == "Admin" || LoginUser.Rights.ORDER_VIEW)
                    {

                        <li class="menu-header fw-medium mt-4">
                            <span class="menu-header-text">Orders Controls</span>
                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Rights">
                            <a href="@Url.Action("ManageOrders", "AdminOrders", new { area = "Products", returnType = 1})" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-order-alphabetical-ascending"></i>
                                <div>Orders List</div>
                            </a>

                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Rights">
                            <a href="@Url.Action("ManageOrders", "AdminOrders", new { area = "Products", returnType = 2 })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-order-bool-descending-variant"></i>
                                <div>Custome Orders List</div>
                            </a>

                        </li>
                    }
                    <!-- Employee Controls -->


                    @if (role == "Admin" || LoginUser.Rights.ROLES_MANAGE)
                    {
                        <li class="menu-header fw-medium mt-4">
                            <span class="menu-header-text">Roles/Rights Controls</span>
                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Rights">
                            <a href="@Url.Action("ManageRights", "Rights", new { area = "Admin" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-shield-account-outline"></i>
                                <div>Manage Rights</div>
                            </a>

                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Roles">
                            <a href="@Url.Action("ManageRoles", "Roles", new { area = "Admin" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-briefcase-outline"></i>
                                <div>Manage Roles</div>
                            </a>
                        </li>
                    }
                    @if (role == "Admin" || LoginUser.Rights.RIGHTS_MANAGE)
                    {
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Assign Rights to Roles">
                            <a href="@Url.Action("AssignRights", "Rights", new { area = "Admin" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-badge-account-outline"></i>
                                <div>Assign Rights</div>
                            </a>
                        </li>
                    }
                    @if (role == "Admin" || LoginUser.Rights.DEPARTMENTS_MANAGE)
                    {
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Deaprtments data">
                            <a href="@Url.Action("ManageDeaprtments", "Departments", new { area = "Admin" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-room-service-outline"></i>
                                <div>Manage Departments</div>
                            </a>
                        </li>
                    }


                    @if (role == "Admin" || LoginUser.Rights.EMPLOYEE_VIEW)
                    {
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Employee data">
                            <a href="@Url.Action("ManageEmployees", "Employees", new { area = "EMS" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-account-multiple-outline"></i>
                                <div>Manage Employees</div>
                            </a>
                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Set Off Days">
                            <a href="@Url.Action("OffDaysForm", "OffDays", new { area = "Admin" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-calendar-remove-outline"></i>
                                <div>Set Off Days</div>
                            </a>
                        </li>
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Set Off Days">
                            <a href="@Url.Action("ManageShiftTimmings", "ShiftTimmings", new { area = "Admin" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-timeline"></i>
                                <div>Set Shift Timmings</div>
                            </a>
                        </li>
                    }


                    <!-- Attendance Controls -->

                    @if (role == "Admin" || LoginUser.Rights.ATTENDANCE_VIEW)
                    {
                        <li class="menu-header fw-medium mt-4">
                            <span class="menu-header-text">Attendance Controls</span>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Mark Attendance">
                            <a href="@Url.Action("AttendanceSheet", "Attendance", new { area = "EMS" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-fingerprint"></i>
                                <div>Mark Attendance</div>
                            </a>
                        </li>
                    }

                    @if (role == "Admin" || LoginUser.Rights.LEAVES_APPROVE)
                    {
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Leave Form">
                            <a href="@Url.Action("LeaveForm", "Leaves", new { area = "EMS" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-file-alert"></i>
                                <div>Leave Form</div>
                            </a>
                        </li>
                    }

                    @if (role == "Admin" || LoginUser.Rights.LEAVES_APPROVE)
                    {
                        <li class="menu-item"
                            data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Leave Form">
                            <a href="@Url.Action("ApproveLeaves", "Leaves", new { area = "EMS" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-calendar-edit-outline"></i>
                                <div>Approve Leaves</div>
                            </a>
                        </li>
                    }


                    @if (role == "Admin" || LoginUser.Rights.DOCUMENT_UPLOAD)
                    {
                        <li class="menu-header fw-medium mt-4">
                            <span class="menu-header-text">DMS Controls</span>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Add Categories">
                            <a href="@Url.Action("ManageDocuments", "Documents", new { area = "DMS" })" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-file-settings-outline"></i>
                                <div>Manage Documents</div>
                            </a>
                        </li>
                    }



                </ul>

            </aside>
            <!-- / Menu -->
            <!-- Layout container -->
            <div class="layout-page">
                <!-- Navbar -->

                <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme"
                     id="layout-navbar">
                    <div class="layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
                        <a class="nav-item nav-link px-0 me-xl-4" href="javascript:void(0)">
                            <i class="mdi mdi-menu mdi-24px"></i>
                        </a>
                    </div>
                    <style>
                        /* Styling the Chat Icon to match professional dashboards */
                        .nav-icon-wrap {
                            position: relative;
                            padding: 0 15px;
                            transition: color 0.2s;
                        }

                            .nav-icon-wrap:hover .mdi-chat {
                                color: #0d6efd; /* Primary blue on hover */
                            }

                        .mdi-chat {
                            font-size: 24px;
                            color: #566a7f;
                        }

                        /* Badge positioning */
                        #mainUnreadBadge {
                            position: absolute;
                            top: 2px;
                            right: 8px;
                            padding: 4px 6px;
                            font-size: 10px;
                            border: 2px solid #fff; /* "Cut-out" effect against background */
                        }

                        /* Avatar styling */
                        .avatar-online img {
                            border: 2px solid transparent;
                            transition: border-color 0.2s;
                        }

                        .avatar-online:hover img {
                            border-color: #0d6efd;
                        }

                        /* Aligning the dropdown menu correctly */
                        .dropdown-menu-end {
                            box-shadow: 0 0.25rem 1rem rgba(161, 172, 184, 0.45);
                            border: none;
                        }
                    </style>
                    <style>
                        #aiSuggestionsWrapper {
                            position: absolute;
                            bottom: 10px;
                            right: 10px;
                            width: 250px;
                            z-index: 2000; /* Ensure it is above chat bubbles */
                            background: #ffffff;
                            border-radius: 12px;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
                            border: 1px solid #ddd;
                            display: none; /* Hidden by default */
                        }

                        .suggestion-pill {
                            background: #f8f9fa;
                            border-radius: 6px;
                            padding: 8px 12px;
                            margin: 5px;
                            font-size: 12px;
                            cursor: pointer;
                            transition: all 0.2s ease;
                            border: 1px solid #eee;
                            display: block; /* Stack them vertically */
                            line-height: 1.4;
                        }

                            .suggestion-pill:hover {
                                background: #e7f3ff;
                                border-color: #0d6efd;
                                color: #0d6efd;
                                transform: translateX(-3px); /* Small slide effect on hover */
                            }

                        .suggestion-item:hover {
                            background-color: #f0f7ff;
                            color: #0d6efd;
                        }

                        #aiSuggestionsList::-webkit-scrollbar {
                            width: 4px;
                        }

                        #aiSuggestionsList::-webkit-scrollbar-thumb {
                            background: #ccc;
                            border-radius: 10px;
                        }

                        /* Styling for the date and unread badge alignment */
                        .group-item h4 {
                            max-width: 180px;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            white-space: nowrap;
                        }

                        .group-item .badge {
                            font-size: 10px;
                            padding: 4px 7px;
                        }

                        .group-item small.text-muted {
                            white-space: nowrap;
                        }
                        /* Container styling */
                        #loadChat {
                            display: flex;
                            flex-direction: column;
                            background-color: #e5ddd5; /* WhatsApp-style light grey/beige background */
                        }

                        /* Sent Messages (Right side) */
                        .chat-sent {
                            background-color: #d1dff9 !important; /* WhatsApp light green */
                            color: #303030;
                            border-bottom-right-radius: 2px !important; /* Sharp corner for sent */
                            box-shadow: 0 1px 1px rgba(0,0,0,0.1);
                            margin-right: 5px;
                        }

                        /* Received Messages (Left side) */
                        .chat-received {
                            background-color: #4a76ce !important; /* White */
                            color: #ffffff;
                            border-bottom-left-radius: 2px !important; /* Sharp corner for received */
                            box-shadow: 0 1px 1px rgba(0,0,0,0.1);
                            margin-left: 5px;
                        }

                        /* Specific small text tweaks */
                        .chat-bubble small {
                            user-select: none;
                        }

                        /* 1. Ensure the dropdown opens BELOW the icon and aligns to the right */
                        #chatbotDiv {
                            top: 100% !important;
                            right: 0 !important;
                            left: auto !important;
                            transform: none !important;
                            margin-top: 10px !important; /* Spacing from the icon */
                            padding: 0;
                            min-height: 200px;
                            width: 400px !important;
                            box-shadow: 0px 5px 20px rgba(1, 41, 112, 0.15);
                            border: none;
                            z-index: 1000;
                        }

                            /* 2. Show the div when the .show class is toggled by your JS */
                            #chatbotDiv.show {
                                display: block !important;
                            }

                        /* 3. Room List specific height and scroll */
                        #chatbotRooms {
                            max-height: 400px;
                            overflow-y: auto;
                            width: 100%;
                        }

                            /* 4. Fix Sticky Header/Footer inside the dropdown */
                            #chatbotRooms .dropdown-header,
                            #chatbotRooms .dropdown-footer {
                                position: sticky;
                                background-color: #fff;
                                z-index: 2;
                            }

                            #chatbotRooms .dropdown-header {
                                top: 0;
                                border-bottom: 1px solid #f1f1f1;
                            }

                            #chatbotRooms .dropdown-footer {
                                bottom: 0;
                                border-top: 1px solid #f1f1f1;
                            }

                        /* Add a hover effect so rooms feel clickable */
                        .message-item.group-item:hover {
                            background-color: #f1f3f8;
                            cursor: pointer;
                        }

                        /* Optional: Make the scrollbar look clean like the chat one */
                        #chatbotRooms::-webkit-scrollbar {
                            width: 5px;
                        }

                        #chatbotRooms::-webkit-scrollbar-thumb {
                            background: #ccc;
                            border-radius: 10px;
                        }

                        /* Keep the headers and footers sticky so they don't scroll away */
                        #chatbotRooms .dropdown-header {
                            position: sticky;
                            top: 0;
                            background-color: white;
                            z-index: 10;
                        }

                        /* Update this block in your style tag */
                        #chatbotRooms .dropdown-footer {
                            position: sticky;
                            bottom: 0;
                            background-color: white;
                            z-index: 10;
                            border-top: 1px solid #ebeef5;
                            display: flex; /* Helps align "Show all" and the "Plus" button */
                            justify-content: space-between;
                            align-items: center;
                        }


                        /* Ensure the floating plus button doesn't get cut off */
                        #private {
                            padding-bottom: 10px;
                        }

                        #userListItems .list-group-item {
                            border-left: none;
                            border-right: none;
                            transition: background 0.2s;
                        }

                            #userListItems .list-group-item:hover {
                                background-color: #f8f9fa;
                            }

                        #userListItems .form-check-input {
                            width: 1.2em;
                            height: 1.2em;
                            cursor: pointer;
                        }


                        /* Ensure both menus have the same width for consistency */
                        #chatbotRooms, #chatbotArea {
                            width: 400px !important;
                            min-width: 400px !important;
                            border: none;
                            box-shadow: 0px 0px 20px rgba(1, 41, 112, 0.1);
                        }

                        /* Ensure the flexbox header uses the full available width */
                        #chatTitle .d-flex {
                            width: 100%;
                        }

                        /* Remove default padding from dropdown-header to give more space to the title */
                        #chatbotArea .dropdown-header {
                            padding: 10px 15px !important;
                        }

                        /* Style for the scrollbar to keep it clean */
                        #loadChat::-webkit-scrollbar {
                            width: 5px;
                        }

                        #loadChat::-webkit-scrollbar-thumb {
                            background: #ccc;
                            border-radius: 10px;
                        }
                    </style>
                    <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">


                        <ul class="navbar-nav flex-row align-items-center ms-auto">

                            <li class="nav-item navbar-dropdown dropdown-user dropdown">
                                <a id="chatboticon" class="nav-link nav-icon" href="javascript:void(0)">
                                    <span class="mdi mdi-chat" style="font-size: 50px"></span>
                                    <span id="mainUnreadBadge" class="badge bg-success badge-number" style="display:none;"></span>
                                </a>

                                <div id="chatbotDiv" class="dropdown-menu dropdown-menu-end dropdown-menu-arrow messages">

                                    <ul id="chatbotRooms" style="list-style: none; padding: 0; margin: 0;">
                                        <li class="dropdown-header">
                                            <span id="headerUnreadText">You have no new messages</span>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>

                                        <div id="ChatRoomsList"></div>

                                        <li class="dropdown-footer d-flex justify-content-end p-2">
                                            @if (LoginUser.Rights.CAN_CHAT_SINGLE_IN_ALL || LoginUser.Rights.CAN_CHAT_SINGLE_IN_TEAM)
                                            {
                                                <button id="privateChatBtn" class="btn btn-primary rounded-circle shadow-sm"
                                                        style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                                                  <span class="mdi mdi-plus"></span>
                                                   
                                                </button>
                                            }
                                        </li>
                                    </ul>

                                    <div id="chatbotArea" style="display:none; position: relative;">
                                        <div class="dropdown-header p-2">
                                            <div id="chatTitle"></div>
                                        </div>
                                        <hr class="dropdown-divider">

                                        <div id="loadChat" style="height: 300px; overflow-y: auto; background: #f8f9fa;"></div>
                                        <div id="userSelectList" style="height: 300px; overflow-y: auto; background: #f8f9fa; padding: 15px 5px; ">
                                            <input type="text" id="userSearch" class="form-control" placeholder="Search User" />
                                            <div id="userListItems">

                                            </div>
                                        </div>


                                        <div id="aiSuggestionsWrapper">
                                            <div class="p-2 border-bottom d-flex justify-content-between align-items-center bg-light" style="border-radius: 12px 12px 0 0;">
                                                <small class="fw-bold text-primary" style="font-size: 10px;"><i class="bi bi-stars"></i> AI SUGGESTIONS</small>
                                                <button type="button" class="btn-close" style="font-size: 8px;" onclick="$('#aiSuggestionsWrapper').fadeOut()"></button>
                                            </div>
                                            <div id="aiSuggestionsList" class="p-1" style="max-height: 180px; overflow-y: auto;">
                                            </div>
                                        </div>

