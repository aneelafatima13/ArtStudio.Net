          // Recursive function to build hierarchy
          function buildFolderTree(folders, parentId, sourceFolderId = null) {
              let html = "<ul class='folder-tree'>";

              // Root ko alag treat karo
              let rootFolder = folders.find(f => f.Id === 0);
              let rootdisabled = (sourceFolderId !== null && parentId === sourceFolderId) ? "disabled" : "";

              if (parentId === 0 && rootFolder) {
                  let fileLabel = "";
                  if (rootFolder.FilesCount === 0) {
                      fileLabel = `Total: 0 Files`;
                  } else if (rootFolder.FilesCount === 1) {
                      fileLabel = `Total: 1 File`;
                  } else {
                      fileLabel = `Total: ${rootFolder.FilesCount} Files`;
                  }

                  // Show breakdown only if there are files
                  let typeBreakdown = rootFolder.FilesCount > 0 && rootFolder.FileCountsByType
                      ? `, ${rootFolder.FileCountsByType}`
                      : "";

                  html += `
        <li>
            <label>
                <input type="checkbox" name="targetFolder" value="0" ${rootdisabled}>
                <b>${rootFolder.FolderName}</b> (${fileLabel}${typeBreakdown})
            </label>
            ${buildSubFolderTree(folders, 0, sourceFolderId)}
        </li>
    `;
                  html += "</ul>";
                  return html;
              }
          }

          function buildSubFolderTree(folders, parentId, sourceFolderId = null) {
              let html = "<ul class='folder-tree'>";

              folders
                  .filter(f => f.ParentFolderId === parentId)
                  .forEach(f => {
                      let disabled = (sourceFolderId !== null && f.Id === sourceFolderId) ? "disabled" : "";

                      // Total file label (singular/plural)
                      let totalLabel = f.FilesCount == 1
                          ? `Total: 1 file`
                          : `Total: ${f.FilesCount} files`;

                      let breakdown = f.FilesCount > 0 && f.FileCountsByType
                          ? `, ${f.FileCountsByType}`
                          : "";

                      html += `
    <li>
        <label>
            <input type="checkbox" name="targetFolder" value="${f.Id}" ${disabled}>
            <b>${f.FolderName}</b> (${totalLabel}, ${breakdown})
        </label>
        ${buildSubFolderTree(folders, f.Id, sourceFolderId)}
    </li>
`;
                  });

              html += "</ul>";
              return html;
          }


