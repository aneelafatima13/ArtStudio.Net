                       'Collegue': 'bg-secondary'
                   };

                   $('#userListItems').html('<div class="text-center p-3"><small class="text-muted">Loading users...</small></div>');

                   $.ajax({
                       url: '@Url.Action("GetIndividualUsers", "Chat", new { area = "BizOneUsers" })',
                       type: 'GET',
                       dataType: 'json',
                       success: function (users) {
                           $("#userListItems").empty();

                           if (!users || users.length === 0) {
                               $("#userListItems").html('<li class="list-group-item text-center">No users found</li>');
                               return;
                           }

                           // Get the base URL for images to replace the ~/ problem
                           // If images are in /assets/img/..., just use a relative path starting with /
                           const defaultImg = "/assets/img/messages-1.jpg";

                           let listHtml = ""; // Build string first for better performance
                           users.forEach(u => {
                               let badgeClass = relationshipColors[u.Relationship] || 'bg-secondary';
