                    }
                } catch (e) {
                    console.error("JSON Parse Error:", e);
                }
            }

            // Set Header Title
            $('#chatTitle').html(`
        <div class="d-flex align-items-center w-100">
            <div onclick="backToRooms()" style="cursor:pointer;" class="me-2 text-secondary">
                <i class="bi bi-arrow-left fs-5"></i>
            </div>
            <h6 class="mb-0 fw-bold" style="font-size: 14px;">${title}</h6>
            ${participantsHtml}
        </div>
    `);

           // Load history and join room
if(typeof loadChatMessages === 'function') loadChatMessages(roomId);

if ($.connection.hub.state === $.signalR.connectionState.connected) {
    $.connection.chatHub.server.joinRoom(roomId, "@LoginUser.EmpId");
}
        }

        function closeParticipantsDropdown() {
            // Finds the button that toggled the current dropdown and hides the dropdown
            var dropdownBtn = document.getElementById('participantDrop');
            var instance = bootstrap.Dropdown.getInstance(dropdownBtn);
            if (instance) {
                instance.hide();
            }
        }


function backToRooms() {
    // Switch UI back
    debugger;
    $('#chatbotArea').hide().removeClass('show');
    $('#chatbotRooms').show().addClass('show');
    loadChatRooms();
        }

        function loadChatMessages(roomId) {
    $('#loadChat').html('<div class="text-center mt-5"><small>Loading messages...</small></div>');

    $.get('@Url.Action("GetChatHistory", "Chat", new { area = "BizOneUsers" })', { roomIdentifier: roomId }, function (messages) {
        $('#loadChat').empty();
        if (messages.length === 0) {
            $('#loadChat').html('<div class="text-center mt-5 text-muted"><small>No messages yet. Say Hi!</small></div>');
        } else {
            messages.forEach(msg => {
                appendMessage(msg.SendingDate, msg.SenderName, msg.MessageText, msg.SenderId == "@LoginUser.EmpId" ? "sent" : "received");
            });
        }
    });
}

        function appendMessage(date, name, text, side) {
            var isSent = (side === "sent");
            var alignClass = isSent ? "justify-content-end" : "justify-content-start";
            var bubbleClass = isSent ? "chat-sent" : "chat-received";

            var html = `
<div class="d-flex ${alignClass} mb-3">
    <div class="chat-bubble ${bubbleClass}" style="max-width: 75%; position: relative; padding: 8px 12px; border-radius: 15px;">
        <small style="display:block; font-weight:bold; font-size:10px; margin-bottom: 2px;">
            ${isSent ? "You" : name}
        </small>
        <div style="font-size: 13px; line-height: 1.5;">${text}</div>
        <small style="display:block; text-align:right; font-size:9px; opacity:0.7; margin-top: 4px;">
            ${date}
        </small>
    </div>
</div>`;

            $('#loadChat').append(html);

            // Auto-scroll to bottom every time a message is appended
            var chatDiv = document.getElementById("loadChat");
            chatDiv.scrollTop = chatDiv.scrollHeight;
        }

    </script>
