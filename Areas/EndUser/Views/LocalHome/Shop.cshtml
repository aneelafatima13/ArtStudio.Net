
@{
    ViewBag.Title = "Shop";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}

<div class="untree_co-section product-section before-footer-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-6">

            </div>
            <div class="col-6 text-end mb-2">
                <button class="btn btn-outline-black" type="button" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar" aria-controls="filterSidebar">
                    <i class="fa fa-filter me-2"></i> Filters
                </button>
            </div>
        </div>
        <div class="row" id="ShopProducts">
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-start" tabindex="-1" id="filterSidebar" style="width: 300px;">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title">Filters</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <div class="mb-3">
            <label title="Search Products by Name, Colour, size, Description, SKU, Product Sources, Brands">Search</label>
            <input type="text" id="txtSearch" class="form-control" placeholder="Search products...">

        </div>
        <div class="mb-3">
            <div id="categoriesWrapper">
                <div class="col-md-12" id="categoriesDiv">
                    <label class="form-label" for="Category">Category</label>
                    <select id="Category" class="form-control category-dropdown" data-level="0">
                        <!-- categories populated dynamically -->
                    </select>
                </div>


            </div>
        </div>

        <div class="mb-3">
            <label>Price Range</label>
            <div class="d-flex gap-2">
                <input type="number" id="minPrice" class="form-control" placeholder="Min">
                <input type="number" id="maxPrice" class="form-control" placeholder="Max">
            </div>
        </div>
        <div class="mb-3">
            <div class="form-check form-switch mb-2">
                <input class="form-check-input OnSale" type="checkbox" id="IsOnSale">
                <label class="form-check-label" for="IsOnSale">On Sale</label>
            </div>
        </div>


        <div class="mb-3" style="display:none" id="discountRateDiv">
            <label class="form-label">Discount Rate (%)</label>
            <input type="number" id="DiscountRate" class="form-control DiscountRate" placeholder="Enter rate %">
        </div>

        <div class="mb-3" style="display:none" id="discountPriceDiv">
            <label class="form-label">Discount Price</label>
            <input type="number" id="DiscountPrice" class="form-control DiscountPrice">
        </div>
        <div class="mb-3">
            <div class="form-check form-switch mb-2">
                <input class="form-check-input OnSale" type="checkbox" id="newP">
                <label class="form-check-label" for="newP">New Products</label>
            </div>
        </div>
        <div class="mb-3">
            <div class="form-check form-switch mb-2">
                <input class="form-check-input NotOnSale" type="checkbox" id="NotOnSale">
                <label class="form-check-label" for="NotOnSale">Not On Sale</label>
            </div>
        </div>
        <div class="mb-3">
            <div class="form-check form-switch mb-2">
                <input class="form-check-input ost" type="checkbox" id="ost">
                <label class="form-check-label" for="ost">Out of Stock</label>
            </div>
        </div>
        <button class="btn btn-black w-100" onclick="loadProducts(1)">Apply Filters</button>
        <button class="btn btn-black w-100 mt-3" onclick="ClearFilters()">Clear Filters</button>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#IsOnSale').on('change', function () {
                if ($(this).is(':checked')) {
                    $('#discountRateDiv, #discountPriceDiv').slideDown();
                } else {
                    $('#discountRateDiv, #discountPriceDiv').slideUp();
                    $('#DiscountRate, #DiscountPrice').val('');
                }
            });
        });
        $(document).ready(function () {
            loadProducts(1);
            loadCategories(); // Load top-level categories on start
        });

        function loadCategories() {
            debugger;
    $.ajax({
        url: '@Url.Action("GetCategories", "Shop", new { area = "Products"})',
        type: 'POST',
        success: function (res) {
            if (res.success) {
                let $cat = $("#Category");
                $cat.empty().append(`<option value="">-- Select Category --</option>`);

                // res.data is now guaranteed to be the array
                res.data.forEach(c => {
                    $cat.append(`<option value="${c.Id}">${c.Name}</option>`);
                });
            } else {
                console.error(res.message);
            }
        }
    });
}

// Handle category/subcategory change
            $(document).on("change", ".category-dropdown", function () {
                debugger;
    let categoryId = $(this).val();
    let level = parseInt($(this).data("level"));

    // Remove deeper category divs
    $(`#categoriesWrapper .category-container`).each(function () {
        if ($(this).data("level") > level) {
            $(this).remove();
        }
    });

    if (categoryId) {
        $.ajax({
            url: '@Url.Action("GetSubCategories", "Shop", new { area = "Products"})',
            type: 'POST',
            data: { parentId: categoryId },
            success: function (res) {
                debugger;
                if (res.length > 0) {
                    let nextLevel = level + 1;

                    // Clone categoriesDiv
                    let $clone = $("#categoriesDiv").clone();
                    $clone.attr("id", `categoriesDiv_${nextLevel}`);
                    $clone.addClass("category-container");
                    $clone.attr("data-level", nextLevel);

                    // Clear old inner content
                    $clone.find("label").remove();
                    $clone.find("select").remove();

                    // Build new dropdown
                    let subSelectId = `SubCategory_${categoryId}_${nextLevel}`;
                    let html = `
                        <label class="form-label" for="${subSelectId}">Select Sub Category</label>
                        <select id="${subSelectId}" class="form-control category-dropdown" data-level="${nextLevel}">
                            <option value="">-- Select Sub Category --</option>
                    `;
                    res.forEach(sc => {
                        html += `<option value="${sc.Id}">${sc.Name}</option>`;
                    });
                    html += `</select>`;

                    $clone.html(html);

                    // Append clone inside wrapper
                    $("#categoriesWrapper").append($clone);
                }
            }
        });
    }
});
       // 1. Updated loadProducts to include categories and close the sidebar
function loadProducts(page) {
    // Collect all checked category IDs into an array
    let categoryId = null;
    $('.category-dropdown').each(function () {
        if ($(this).val()) {
            categoryId = $(this).val();
        }
    });

    const filterData = {
        page: page,
        pageSize: 12,
        categoryId: categoryId,
        minPrice: $('#minPrice').val(),
        maxPrice: $('#maxPrice').val(),
        search: $('#txtSearch').val(),
        drate: $('#DiscountRate').val(),
        dprice: $('#DiscountPrice').val(),
        onSale: $('#IsOnSale').is(':checked') ? true : null,
        notonSale: $('#NotOnSale').is(':checked') ? false : null,
        newProducts: $('#newP').is(':checked') ? true : null, // Send true/false
        inStock: $('#ost').is(':checked') ? false : null // If "Out of Stock" checked, we show everything? Usually, this filters for Stock > 0.
    };
    debugger;
    $.ajax({
        url: '@Url.Action("Index", "Shop", new { area = "Products" })',
        type: 'GET',
        data: filterData,
        traditional: true, // Required to send arrays correctly in the URL query string
        success: function (response) {
            if (response.success) {
                renderProducts(response);
                renderPagination(response.total, response.page);

                // Close the Offcanvas
                const filterEl = document.getElementById('filterSidebar');
                const instance = bootstrap.Offcanvas.getInstance(filterEl);
                if (instance) instance.hide();
            } else {
                // Handle logic error (e.g., DB connection failed)
                alert("Error: " + response.message);
            }
        },
        error: function (xhr, status, error) {
            // Handle HTTP errors (e.g., 404, 500)
            console.error("AJAX Error: ", error);
            alert("Something went wrong on the server.");
        }
    });
}
        function ClearFilters() {

            $('#txtSearch, #minPrice, #maxPrice, #DiscountRate, #DiscountPrice').val('');

            $('#IsOnSale, #ost, #newP, #NotOnSale').prop('checked', false);

            $('.category-dropdown').val('');

            $('.category-checkbox').prop('checked', false);

            $('.discountRateDiv, .discountPriceDiv').hide();

            $('.child-container').empty();

            loadProducts(1);
        }

        function renderProducts(response) {
            const container = $('#ShopProducts');
            container.empty();

            // Use response.data because that's where the product list is now
            const products = response.data;
            const symbol = response.currencySymbol || 'Rs.'; // Fallback if symbol is missing

            if (!products || products.length === 0) {
                container.append('<div class="col-12 text-center"><h3>No products found.</h3></div>');
                return;
            }

            products.forEach(item => {
                // --- 1. Image Logic ---
                const rawPath = (item.firstVarientproductImages && item.firstVarientproductImages.length > 0)
                    ? item.firstVarientproductImages[0].ImagePath : '';
                const imageSource = rawPath ? `/Products/Shop/GetImg?path=${encodeURIComponent(rawPath)}` : '/FurniAssets/images/product-1.png';

                // --- 2. Price Logic (Using Converted Values from Server) ---
                let priceHtml = '';
                // If ConvertedDiscountPrice exists and is lower than the regular price
                if (item.OnSale && item.ConvertedDiscountPrice && item.ConvertedDiscountPrice < item.ConvertedPrice) {
                    priceHtml = `<del class="text-muted me-2">${symbol}${item.ConvertedPrice.toFixed(2)}</del>
                         <span class="text-danger">${symbol}${item.ConvertedDiscountPrice.toFixed(2)}</span>`;
                } else {
                    priceHtml = `${symbol}${item.ConvertedPrice.toFixed(2)}`;
                }

                // --- 3. Badge Logic ---
                let badgeHtml = '';
                const isOutOfStock = (item.StockQuantity <= 0 || !item.InStock); // Boolean check

                if (isOutOfStock) {
                    badgeHtml = '<span class="badge bg-danger position-absolute" style="top:10px; left:10px; z-index:2;">Out of Stock</span>';
                } else if (item.OnSale) {
                    let saleText = item.DiscountRate > 0 ? `Sale ${item.DiscountRate}% Off` : "On Sale";
                    badgeHtml = `<span class="badge bg-primary position-absolute" style="top:10px; left:10px; z-index:2;">${saleText}</span>`;
                }
                // --- 4. Render HTML ---
                const productHtml = `
    <div class="col-12 col-md-4 col-lg-3 mb-5">
        <div class="product-item position-relative ${isOutOfStock ? 'out-of-stock-item' : ''}">
            ${badgeHtml}
            <div style="width: 100%; height: 250px; overflow: hidden; background: #f9f9f9; display: flex; align-items: center; justify-content: center; border-radius: 10px;">
                <img src="${imageSource}" class="img-fluid product-thumbnail" style="${isOutOfStock ? 'filter: grayscale(1); opacity: 0.6;' : ''} max-height: 100%; max-width: 100%;">
            </div>

            <h3 class="product-title mt-3" style="cursor:pointer" onclick="viewItem(event,${item.Id},${item.VariantId || 0})">${item.Name}</h3>

            <strong class="product-price">
                ${priceHtml}
            </strong>

            ${/* Disable Click if Out of Stock */
                    isOutOfStock
                        ? `<span class="icon-cross disabled-btn" style="background: #ccc; cursor: not-allowed;" title="Out of Stock">
                    <img src="/FurniAssets/images/cross.svg" class="img-fluid" style="filter: brightness(0.5);">
                 </span>`
                        : `<span class="icon-cross" onclick="addToCart(event,${item.Id},${item.VariantId || 0})" title="Add to Cart">
                    <img src="/FurniAssets/images/cross.svg" class="img-fluid">
                 </span>`
                    }
        </div>
    </div>`;
                container.append(productHtml);
            });
        }

        function renderPagination(totalCount, currentPage) {
            const pageSize = 12;
            const totalPages = Math.ceil(totalCount / pageSize);
            const container = $('#paginationControls');
            container.empty();

            for (let i = 1; i <= totalPages; i++) {
                const activeClass = (i === currentPage) ? 'btn-black' : 'btn-outline-black';
                const btn = `<button onclick="loadProducts(${i})" class="btn btn-sm ${activeClass} me-1">${i}</button>`;
                container.append(btn);
            }
        }

       function addToCart(event, productId, VariantId) {
    event.preventDefault();
    event.stopPropagation();

    $.ajax({
        url: '@Url.Action("AddToCart", "Cart", new { area = "EndUser" })',
        type: 'POST',
        data: { id: productId, quantity: 1, VariantId: VariantId },
        success: function (response) {
            if (response.success) {
                // 1. Update Badge Logic
                const badge = $('#cart-badge');
                badge.text(response.newCount);

                if (response.newCount > 0) {
                    badge.show();
                }

                badge.fadeOut(100).fadeIn(100);

                // 2. SweetAlert2 Success Toast
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true
                });

                Toast.fire({
                    icon: 'success',
                    title: 'Item added to cart'
                });

            } else {
                // Error Popup
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: response.message || "Error adding to cart.",
                    confirmButtonColor: '#3085d6'
                });
            }
        },
        error: function() {
            Swal.fire({
                icon: 'error',
                title: 'Connection Error',
                text: 'Could not reach the server. Please try again.'
            });
        }
    });
}
        function viewItem(event, id, VariantId) {
            // Prevent default behavior if nested in other clickable elements
            if (event) event.stopPropagation();

            // Redirect to the ProductDetails Action
            window.location.href = '@Url.Action("ProductDetails", "Shop", new { area = "Products" })?Id=' + id + '&VariantId=' + VariantId;
        }
    </script>
}