@{
    ViewBag.Title = "Orders";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}

@if (ViewBag.ReturnType == 1)
{
    <div class="container">
        <div class="alert alert-success mt-4">
            Your Order has been placed successfully!
        </div>
    </div>
}

<div class="untree_co-section before-footer-section">
    <div class="container">
        <div id="OrdersList">
        </div>

        <div class="row mt-5">
            <div class="col-12 text-center">
                <div id="pagination-controls" class="btn-group">
                    <button class="btn btn-outline-black btn-sm" id="prevPage" onclick="changePage(-1)">Previous</button>
                    <span class="btn btn-sm" id="currentPageDisplay" style="pointer-events: none;">Page 1</span>
                    <button class="btn btn-outline-black btn-sm" id="nextPage" onclick="changePage(1)">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

@* Use @ViewBag.CustomerId directly in the hidden field *@
<input type="hidden" id="c_id" value="@ViewBag.CustomerId" />

@section scripts{
    <script>
        var currentPage = 1;
        var pageSize = 10;

        $(document).ready(function () {
            loadOrders(currentPage);
        });

        function changePage(step) {
            currentPage += step;
            loadOrders(currentPage);
        }

    function loadOrders(page) {
    var customerId = $('#c_id').val();

    $.ajax({
        url: '@Url.Action("GetCustomerOrders", "Orders", new { area = "Products" })',
        type: 'GET',
        data: { customerId: customerId, pageNumber: page, pageSize: pageSize },
        beforeSend: function() {
            $('#OrdersList').html('<div class="text-center p-5"><h4>Loading your orders...</h4></div>');
        },
        success: function (response) {
            if (response.data && response.data.length > 0) {
                var html = "";

                $.each(response.data, function (key, order) {
                    // 1. Date formatting
                    var date = new Date(parseInt(order.OrderDate.substr(6)));

                    // 2. Logic: Define Coupon Badge BEFORE the header HTML
                    // We check if order.CouponCode exists and if there was an actual discount
                    let couponHeaderBadge = "";
                    if (order.CouponCode) {
                        couponHeaderBadge = `
                    <span class="badge rounded-pill bg-success ms-2" style="font-size: 0.8rem;">
                        <i class="fa fa-tag me-1"></i> Coupon: ${order.CouponCode} (-Rs. ${order.CouponDiscount.toFixed(0)})
                    </span>`;
                    }

                    // 3. Build Header with the Badge
                    html += `
            <div class="card mb-5 shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div>
                            <h5 class="mb-0 text-dark fw-bold d-inline-block">Order #${order.OrderNo}</h5>
                            ${couponHeaderBadge} 
                            <div class="mt-1">
                                <small class="text-muted">Placed on: ${date.toLocaleDateString()} ${date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</small>
                            </div>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-dark px-3 py-2">Status: Paid</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end pe-4">Total</th>
                            </tr>
                        </thead>
                        <tbody>`;

                    // 4. Nested Items Loop
                    $.each(order.Items, function (i, product) {
                        const imageSrc = product.ImgPath
                            ? `/Products/Shop/GetImg?path=${encodeURIComponent(product.ImgPath)}`
                            : '/FurniAssets/images/product-1.png';

                        html += `
                <tr>
                    <td class="ps-4">
                        <div class="d-flex align-items-center">
                            <img src="${imageSrc}" class="rounded border" style="width: 50px; height: 50px; object-fit: cover; margin-right:15px;">
                            <div>
                                <span class="d-block fw-bold">${product.Name}</span>
                                <small class="text-muted">${product.ItemDetails || ''}</small>
                            </div>
                        </div>
                    </td>
                    <td class="text-center align-middle">${product.Quantity}</td>
                    <td class="text-end align-middle">Rs. ${product.Price.toFixed(2)}</td>
                    <td class="text-end align-middle pe-4">Rs. ${(product.Price * product.Quantity).toFixed(2)}</td>
                </tr>`;
                    });

                    html += `</tbody></table></div>`;

                    // 5. Footer with detailed breakdown
                    let couponRow = (order.CouponCode)
                        ? `<div class="d-flex justify-content-between mb-1 text-success fw-bold">
                        <span>Coupon Savings (${order.CouponCode}):</span>
                        <span>- Rs. ${order.CouponDiscount.toFixed(2)}</span>
                   </div>`
                        : '';

                    html += `
                <div class="card-footer bg-light border-top-0 py-3">
                    <div class="row justify-content-end text-end">
                        <div class="col-md-5 col-12 pe-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Subtotal:</span>
                                <span>Rs. ${order.Subtotal.toFixed(2)}</span>
                            </div>
                            ${couponRow}
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Shipping:</span>
                                <span>Rs. ${order.ShippingAmount.toFixed(2)}</span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong class="text-dark">Grand Total:</strong>
                                <strong class="text-primary fs-4">Rs. ${order.GrandTotal.toFixed(2)}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`; // Close Card
                });

                $('#OrdersList').html(html);
                updatePaginationControls(response.data.length, page);
            }
        }
    });
}

function updatePaginationControls(count, page) {
    $('#currentPageDisplay').text("Page " + page);
    $('#prevPage').prop('disabled', page === 1);
    $('#nextPage').prop('disabled', count < pageSize);
    $('#pagination-controls').show();
}
    </script>
}
