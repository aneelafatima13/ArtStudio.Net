               });

               chat.client.updateGlobalUnreadCount = function () {
                   console.log("Refreshing global unread count...");
                   updateMainUnreadCount(); // This calls your AJAX function to get the new count from DB
               };

chat.client.receiveMessage = function (sendingDate, senderId, senderName, message, roomId) {
    // Only append if the message belongs to the room we are currently looking at
    if (currentRoomId == roomId) {
        let currentCount = parseInt($('#notifCount').text()) || 0;
        $('#notifCount').text(currentCount + 1);
        // Compare senderId with the logged-in User ID
        var side = (senderId == "@LoginUser.EmpId") ? "sent" : "received";

        appendMessage(sendingDate, senderName, message, side);

        // Auto-scroll to bottom
        var chatDiv = document.getElementById("loadChat");
        if (chatDiv) {
            chatDiv.scrollTop = chatDiv.scrollHeight;
        }
    } else {
        // New message in a closed room -> Increment Global Count
        updateMainUnreadCount();
    }
               };


               // Monitor checkbox changes
               $(document).on('change', '.user-checkbox', function () {
                   var selectedCount = $('.user-checkbox:checked').length;
