
@{
    ViewBag.Title = "Cart";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}

<div class="untree_co-section before-footer-section">
    <div class="container">
        <div class="row mb-5">
            <div id="coupensList"></div>
            <form class="col-md-12" method="post">
                <div id="activeCouponContainer" class="mb-4" style="display:none;">
                    <div class="alert alert-success d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fa fa-ticket-alt me-2"></i>
                            <strong>Coupon Applied: </strong> <span id="displayCouponCode" class="badge bg-dark"></span>
                            <small id="couponShortDesc" class="ms-2 text-muted"></small>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" onclick="removeCoupon()">Remove</button>
                    </div>
                </div>

                <div class="site-blocks-table">
                    <table class="table" id="cartItems">
                        <thead>
                            <tr>
                                <th class="product-name">Product Details</th>
                                <th class="product-price">Price Analysis</th>
                                <th class="product-quantity">Quantity</th>
                                <th class="product-total">Row Total</th>
                                <th class="product-remove">Action</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </form>
        </div>

        <div class="row">
            <div class="col-md-6">
                
                <div class="row">
                    <div class="col-md-12">
                        <label class="text-black h4" for="coupon">Coupon</label>
                        <p>Enter your coupon code if you have one.</p>
                    </div>
                    <div class="col-md-8 mb-3 mb-md-0">
                        <input type="text" class="form-control py-3" id="coupon" placeholder="Coupon Code">
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-black" id="varifyCoupen" onclick="applyCoupen()">Apply Coupon</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6 pl-5">
                <div class="row justify-content-end">
                    <div class="col-md-7">
                        <div class="row">
                            <div class="col-md-12 text-right border-bottom mb-5">
                                <h3 class="text-black h4 text-uppercase">Cart Totals</h3>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <span class="text-black">Subtotal</span>
                            </div>
                            <div class="col-md-6 text-right">
                                <strong class="text-black" id="cart-raw-subtotal">0.00</strong>
                            </div>
                        </div>

                        <div class="row mb-3" id="discount-row" style="display:none;">
                            <div class="col-md-6">
                                <span class="text-success">Discount (<span id="applied-coupon-label"></span>)</span>
                            </div>
                            <div class="col-md-6 text-right">
                                <strong class="text-success" id="cart-discount-amount">-0.00</strong>
                            </div>
                        </div>

                        <div class="row mb-5">
                            <div class="col-md-6">
                                <span class="text-black">Total</span>
                            </div>
                            <div class="col-md-6 text-right">
                                <strong class="text-black" id="cart-final-total">0.00</strong>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <button class="btn btn-black btn-lg py-3 btn-block" onclick="proceedToCheckout()">Proceed To Checkout</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<input type="hidden" id="appliedCouponToken" value="" />
@section Scripts {
    <script>
        let currentSymbol = "Rs."; // Global variable for the cart

        $(document).ready(function () {
            loadCart();


        });
function loadCoupens() {
    $.ajax({
        url: '@Url.Action("GetCoupens", "Cart", new { area = "EndUser" })',
        type: 'GET',
        success: function (res) {
            if (res.success && res.data.length > 0) {
                // Get the list of codes already in the cart from our hidden field or a global array
                // We'll populate this in loadCart
                const appliedCodes = $('#appliedCouponTokens').val().split(',');

                var html = '<div class="row g-3">';
                res.data.forEach(function (coupon) {
                    var benefit = "";
                    if (coupon.DiscountRate > 0) {
                        benefit = coupon.DiscountRate + "% OFF";
                    } else if (coupon.DiscountPrice > 0) {
                        benefit = "Flat " + coupon.DiscountPrice + " OFF";
                    } else if (coupon.CouponType.includes("FreeShipping")) {
                        benefit = "FREE SHIPPING";
                    } else {
                        benefit = "SPECIAL OFFER";
                    }
                    const isApplied = appliedCodes.includes(coupon.CouponCode);
                    const btnAttr = isApplied ? 'disabled' : '';
                    const btnText = isApplied ? 'Applied' : 'Use';
                    const btnClass = isApplied ? 'btn-success' : 'btn-primary';

                    html += `
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-dashed shadow-none" style="border: 2px dashed #666cff; background-color: ${isApplied ? '#e8fadf' : '#f4f5ff'};">
                                <div class="card-body p-3 text-center">
                                    <div class="badge bg-primary mb-2">${coupon.CouponType}</div>
                                    <h4 class="mb-1 text-primary fw-bold">${benefit}</h4>
                                    <p class="small text-muted mb-2">Min. Order: ${coupon.minorderprice || 0}</p>
                                    <div class="d-flex justify-content-between small">
                                        <span class="text-danger"><i class="mdi mdi-calendar-clock"></i> ${expiry}</span>
                                        <button class="btn btn-xs ${btnClass}" ${btnAttr} onclick="loadCart('${coupon.CouponCode}')">${btnText}</button>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                });
                $('#coupensList').html(html + '</div>');
            }
        }
    });
}


        function loadCart(couponCode = "") {
    const appliedCode = couponCode || ""; // If removing, pass empty string
    $.ajax({
        url: '@Url.Action("GetCartItems", "Cart", new { area = "EndUser" })',
        type: 'GET',
        data: { code: appliedCode },
        success: function (res) {
            if (res.success) {
                // Store applied codes in a hidden field as a comma-separated string
                $('#appliedCouponTokens').val(res.appliedCodes.join(','));

                currentSymbol = res.symbol;
                renderCartTable(res.data.Items, res.data.AppliedCoupons); // Note: You might need to update renderCartTable to handle a list
                updateTotals(res.rawSubtotal, res.discount, res.subtotal, res.appliedCodes.join(', '));
                loadCoupens(); // Refresh the card buttons
            }
        }
    });
}

// Function to remove the coupon
function removeCoupon() {
    Swal.fire({
        title: 'Remove Coupon?',
        text: "Are you sure you want to remove the applied discount?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Yes, remove it!'
    }).then((result) => {
        if (result.isConfirmed) {
            $.ajax({
                url: '@Url.Action("RemoveCoupon", "Cart", new { area = "EndUser" })',
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        loadCart(""); // Reload cart with no code
                        Swal.fire('Removed!', 'The coupon has been removed.', 'success');
                    }
                }
            });
        }
    });
}


        function renderCartTable(items, couponslist) {
            const tbody = $('#cartItems tbody');
            tbody.empty();

            // 1. Handle Active Coupon UI and Implementation Summary
            couponslist.forEach(couponData => {
                if (couponData && couponData.CouponCode) {
                    let implementationDetail = "";
                    const discountVal = couponData.DiscountRate > 0
                        ? `${couponData.DiscountRate}%`
                        : `${currentSymbol}${couponData.DiscountPrice}`;

                    // Generate dynamic summary based on CouponType
                    switch (couponData.CouponType) {
                        case "Discount":
                            implementationDetail = `Applied ${discountVal} discount on the total order value.`;
                            break;
                        case "DiscountWithoutSaleItems":
                            implementationDetail = `Applied ${discountVal} discount only on non-sale items.`;
                            break;
                        case "Discount1stItem":
                            implementationDetail = `Applied ${discountVal} discount on the first unit of each product.`;
                            break;
                        case "BOGO":
                            implementationDetail = `Buy 1 Get 1 Free: 100% discount applied to every second unit of a product.`;
                            break;
                        case "BTGO":
                            implementationDetail = `Buy 2 Get 1 Free: Every third unit is free.`;
                            break;
                        case "Free Shipping":
                            implementationDetail = `Standard shipping charges have been waived.`;
                            break;
                        default:
                            implementationDetail = `Coupon applied successfully to your cart.`;
                    }

                    $('#activeCouponContainer').fadeIn();
                    $('#displayCouponCode').text(couponData.CouponCode);

                    // Show the Type and the Implementation Explanation
                    $('#couponShortDesc').html(`
            <br><small class="text-primary fw-bold">Type: ${couponData.CouponType}</small>
            <br><small class="text-dark"><strong>How it works:</strong> ${implementationDetail}</small>
        `);
                } else {
                    $('#activeCouponContainer').hide();
                }
            });

            // 2. Render Items
            items.forEach(item => {
                const imageSrc = item.ImgPath ? `/Products/Shop/GetImg?path=${encodeURIComponent(item.ImgPath)}` : '/FurniAssets/images/product-1.png';

                // Column: Product Details
                let productDetailsHtml = `
            <div class="d-flex align-items-center">
                <img src="${imageSrc}" class="img-fluid rounded border me-3" style="width: 70px; height: 70px; object-fit: cover;">
                <div class="text-start">
                    <h2 class="h6 text-black mb-0">${item.Name}</h2>
                    ${item.VariantId ? '<span class="badge bg-secondary" style="font-size: 0.7rem;">Variant</span>' : ''}
                    ${item.VariantInfo ? `<br><small class="text-muted">${item.VariantInfo}</small>` : ''}
                </div>
            </div>`;

                // Column: Price Analysis (Showing Item-Level Coupon Impact)
                let priceHtml = `
            <div class="text-start">
                <div class="text-muted" style="text-decoration: ${item.OnSale ? 'line-through' : 'none'}; font-size: 0.85rem;">
                    ${currentSymbol} ${item.ActualPrice.toFixed(2)}
                </div>
                ${item.OnSale ? `
                    <div class="mb-1">
                        <span class="badge bg-danger" style="font-size: 0.65rem;">SALE ${item.DiscountRate}% OFF</span><br>
                        <strong>${currentSymbol} ${item.PriceafterApplysalediscount.toFixed(2)}</strong>
                    </div>` : ''}

                ${item.DiscountPricebyCoupon > 0 ? `
                    <div class="mt-1">
                        <span class="badge bg-success" style="font-size: 0.65rem;">COUPON APPLIED</span><br>
                        <small class="text-success fw-bold">Saved ${currentSymbol}${item.DiscountPricebyCoupon.toFixed(2)}</small>
                    </div>` : ''}
            </div>`;

                const row = `
            <tr>
                <td class="product-name">${productDetailsHtml}</td>
                <td>${priceHtml}</td>
                <td>
                    <div class="input-group mb-1 d-flex align-items-center justify-content-center" style="max-width: 120px; margin: auto;">
                        <button class="btn btn-outline-black btn-sm" onclick="changeQty(${item.ProductId}, ${item.VariantId || 0}, -1)">&minus;</button>
                        <input type="text" class="form-control text-center quantity-amount border-0" value="${item.Quantity}" readonly>
                        <button class="btn btn-outline-black btn-sm" onclick="changeQty(${item.ProductId}, ${item.VariantId || 0}, 1)">&plus;</button>
                    </div>
                    <small class="text-muted" style="font-size: 0.7rem;">Stock: ${item.StockQty}</small>
                </td>
                <td class="product-total">
                    <strong class="text-black">${currentSymbol} ${item.Total1UnitPrice.toFixed(2)}</strong>
                </td>
                <td><button onclick="removeItem(${item.ProductId}, ${item.VariantId || 0})" class="btn btn-sm text-danger"><i class="fa fa-trash"></i></button></td>
            </tr>`;
                tbody.append(row);
            });
        }

        function updateTotals(rawSubtotal, discount, finalTotal, couponCode) {
            $('#cart-raw-subtotal').text(`${currentSymbol} ${rawSubtotal.toFixed(2)}`);
            $('#cart-final-total').text(`${currentSymbol} ${finalTotal.toFixed(2)}`);

            if (discount > 0) {
                $('#discount-row').show();
                $('#applied-coupon-label').text(couponCode);
                $('#cart-discount-amount').text(`-${currentSymbol} ${discount.toFixed(2)}`);
            } else {
                $('#discount-row').hide();
            }
        }
        function changeQty(productId, variantId, change) {
            // Fixed ID selector to include variantId
            const input = $(`#qty-${productId}-${variantId}`);
            const currentQty = parseInt(input.val());
            const maxStock = parseInt(input.data('stock'));

            if (change > 0 && currentQty >= maxStock) {
                alert(`Only ${maxStock} items available in stock.`);
                return;
            }
            if (change < 0 && currentQty <= 1) {
                removeItem(productId, variantId);
                return;
            }

            $.ajax({
                url: '@Url.Action("UpdateQuantity", "Cart", new { area = "EndUser" })',
                type: 'POST',
                data: { id: productId, VariantId: variantId, change: change },
                success: function (response) {
                    if (response.success) {
                        loadCart();
                        updateBadge();
                    }
                }
            });
        }

        function removeItem(productId, variantId) {
            if (confirm("Are you sure you want to remove this item?")) {
                $.ajax({
                    url: '@Url.Action("RemoveFromCart", "Cart", new { area = "EndUser" })',
                    type: 'POST',
                    data: { id: productId, VariantId: variantId },
                    success: function (response) {
                        if (response.success) {
                            loadCart();
                            updateBadge();
                        }
                    }
                });
            }
        }

        function updateBadge() {
            $.get('@Url.Action("GetCartCount", "Cart", new { area = "EndUser" })', function(data) {
                const badge = $('#cart-badge');
                badge.text(data.count);
                data.count > 0 ? badge.show() : badge.hide();
            });
        }

         function proceedToCheckout() {
                window.location.href = '@Url.Action("Checkout", "Checkout", new { area = "EndUser" })';

        }

        let tempCouponData = null; // Store data temporarily before confirmation

function applyCoupen() {
    const code = $('#coupon').val().trim();
    
    if (!code) {
        Swal.fire('Error', "Please enter a coupon code", 'error');
        return;
    }

    $.ajax({
        // Updated 'Varify' to 'Verify' to match C# Controller
        url: '@Url.Action("VerifyCouponCode", "Cart", new { area = "EndUser"})',
        type: "GET",
        data: { code: code },
        success: function (res) {
            if (res.success) {
                const tempCouponData = res.CoupenData;

                // 1. Dynamic Benefit Text
                let benefitText = "";
                if (tempCouponData.CouponType.includes("Shipping")) {
                    benefitText = "Free Shipping";
                } else if (tempCouponData.DiscountValue > 0) {
                    // Best practice: Show actual money saved
                    benefitText = `${currentSymbol} ${tempCouponData.DiscountValue.toFixed(2)} Off`;
                } else {
                    benefitText = `${tempCouponData.DiscountRate}% Off`;
                }

                // 2. Show Modal
                Swal.fire({
                    title: 'Coupon Applied!',
                    html: `
                        <div class="text-start border-top pt-3">
                            <p class="mb-2"><strong>Code:</strong> <span class="badge bg-dark">${tempCouponData.CouponCode}</span></p>
                            <p class="mb-2"><strong>Offer:</strong> ${tempCouponData.CouponType}</p>
                            <p class="mb-0"><strong>Your Savings:</strong> <span class="text-success fw-bold">${benefitText}</span></p>
                            <hr>
                            <p class="small text-muted italic">Click continue to update your order total.</p>
                        </div>`,
                    icon: 'success', // Changed to success because the code is valid
                    showCancelButton: true,
                    confirmButtonText: 'Continue',
                    cancelButtonText: 'Cancel',
                    confirmButtonColor: '#000'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // RE-LOAD cart with the code
                        loadCart(tempCouponData.CouponCode);
                        $('#coupon').val('');
                    }
                });
            } else {
                Swal.fire('Invalid Coupon', res.message, 'error');
            }
        },
        error: function() {
            Swal.fire('Error', 'Something went wrong. Please try again.', 'error');
        }
    });
}
    </script>
}