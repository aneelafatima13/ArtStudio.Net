@{
    ViewBag.Title = "ManageEmployees";
    Layout = "~/Views/Shared/_BizoneLayout.cshtml";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="row">
        <div class="col-md-12">
            <ul class="nav nav-pills mb-3" role="tablist" id="tabsbuttons">
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link waves-effect waves-light active" role="tab" data-bs-toggle="tab" data-bs-target="#navs-pills-top-list" aria-controls="navs-pills-top-list" aria-selected="true">
                        Employees List
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link waves-effect waves-light" role="tab" data-bs-toggle="tab" data-bs-target="#navs-pills-top-form" aria-controls="navs-pills-top-form" aria-selected="false" tabindex="-1">
                        Employee Form
                    </button>
                </li>

            </ul>
            <div class="tab-content">

                <div class="tab-pane fade active show" id="navs-pills-top-list" role="tabpanel">
                    <div class="card mb-4">
                        <h5 class="card-header">Employees List</h5>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">

                                </div>
                                <div class="col-md-4">
                                    <input type="search" class="form-control" placeholder="Search.." id="search" />
                                </div>
                            </div>
                            <br />
                            <table id="empTable"
                                   class="table table-hover align-middle shadow-sm rounded">
                                <thead style="background-color: #3b5d50">
                                    <tr>
                                        <th scope="col" style="color: white!important">Full Name</th>
                                        <th scope="col" style="color: white!important">Department</th>
                                        <th scope="col" style="color: white!important" class="text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Rows will be loaded dynamically -->
                                </tbody>

                            </table>


                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="navs-pills-top-form" role="tabpanel">
                    <div class="card mb-4">
                        <h5 class="card-header">Add Employee Info</h5>
                        <div class="card-body">
                            <form id="formAuthentication" enctype="multipart/form-data">

                                <div class="divider text-start-center divider-primary">
                                    <div class="divider-text fw-bold">Personal Info</div>
                                </div>
                                @*<h6 class="mb-3 fw-bold">Personal Info</h6>*@
                                <div class="row g-3 mb-5">
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">First Name</label>
                                        <input type="text" class="form-control" placeholder="John" id="firstName">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Last Name</label>
                                        <input type="text" class="form-control" placeholder="Doe" id="lastName">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Full Name</label>
                                        <input type="text" class="form-control" placeholder="John Doe" id="fullName">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Father Name</label>
                                        <input type="text" class="form-control" placeholder="Doe Josph" id="fatherName">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">CNIC</label>
                                        <input type="text" class="form-control" placeholder="12345-1234567-1" id="cnic">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Date of Birth</label>
                                        <input type="date" class="form-control" placeholder="10 May 1990" id="dob">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Age</label>
                                        <input type="number" class="form-control" placeholder="40" id="age">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Religion</label>
                                        <input type="text" class="form-control" placeholder="Islam" id="religion">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Nationality</label>
                                        <input type="text" class="form-control" placeholder="Pakistani" id="nationality">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Gender</label>
                                        <br />
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="gender" id="inlineRadio1" value="Male">
                                            <label class="form-check-label" for="inlineRadio1">Male</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="gender" id="inlineRadio2" value="Female">
                                            <label class="form-check-label" for="inlineRadio2">Female</label>
                                        </div>
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Marital Status</label>
                                        <br />
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="maritalStatus" id="inlineRadio3" value="Male">
                                            <label class="form-check-label" for="inlineRadio3">Single</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="maritalStatus" id="inlineRadio4" value="Female">
                                            <label class="form-check-label" for="inlineRadio4">Married</label>
                                        </div>

                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <div class="mb-3">
                                            <label for="uploadImage" class="form-label">Upload Image</label>
                                            <input class="form-control" type="file" id="uploadImage" name="files" data-title="EmpImage">
                                        </div>

                                    </div>

                                </div>
                                <div class="divider text-start-center divider-primary">
                                    <div class="divider-text fw-bold">Contact Info</div>
                                </div>

                                <div class="row g-3 mb-5">
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Phone No</label>
                                        <input type="text" class="form-control" placeholder="+92 300 1234567" id="phone1">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Phone No (Alternate)</label>
                                        <input type="text" class="form-control" placeholder="+92 300 7654321" id="phone2">
                                    </div>

                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Email</label>
                                        <input type="email" class="form-control" placeholder="john@example.com" id="email1">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Email (Alternate)</label>
                                        <input type="email" class="form-control" placeholder="john@example.com" id="email2">
                                    </div>

                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Address</label>
                                        <input type="text" class="form-control" placeholder="Street Address" id="address">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Provence</label>
                                        <input type="text" class="form-control" placeholder="Punjab" id="provence">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">City</label>
                                        <input type="text" class="form-control" placeholder="Karachi" id="city">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Country</label>
                                        <input type="text" class="form-control" placeholder="Pakistan" id="country">
                                    </div>
                                </div>
                                <div class="divider text-start-center divider-primary">
                                    <div class="divider-text fw-bold">Credentials Info</div>
                                </div>

                                <div class="row g-3 mb-5">
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Username</label>
                                        <input type="text" class="form-control" placeholder="john.doe" id="newusername">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Password</label>
                                        <input type="password" class="form-control" placeholder="password" id="password">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">My Role</label>
                                        <select id="myrolesList" class="form-select form-select-lg">
                                        </select>
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Roles Under Me</label>
                                        <select id="rolesListunderme" class="form-select form-select-lg" multiple>
                                        </select>
                                    </div>

                                </div>

                                <div class="divider text-start-center divider-primary">
                                    <div class="divider-text fw-bold">Job Info</div>
                                </div>
                                <div class="row g-3 mb-5">
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Department</label>
                                        <select id="departmentsList" class="form-select form-select-lg">
                                        </select>
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Designation</label>
                                        <input type="text" class="form-control" placeholder="Manager" id="designation">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Joining Date</label>
                                        <input type="date" class="form-control" placeholder="10 May 2024" id="joiningDate">
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Salary</label>
                                        <input type="text" class="form-control" placeholder="50,000" id="salary">
                                    </div>

                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Shift</label>
                                        <br />
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="shift" id="inlineRadio9" value="Male">
                                            <label class="form-check-label" for="inlineRadio9">Day</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="shift" id="inlineRadio10" value="Female">
                                            <label class="form-check-label" for="inlineRadio10">Night</label>
                                        </div>
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Shift Timming</label>
                                        <select id="shiftTimmingsList" class="form-select form-select-lg">
                                        </select>
                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <div class="mb-3">
                                            <label for="formFileCV" class="form-label">Upload CV</label>
                                            <input class="form-control" type="file" id="formFileCV" name="files" data-title="EmpCV">
                                        </div>

                                    </div>
                                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                                        <label class="form-label">Is Active</label>
                                        <div class="form-check form-switch mb-2">
                                            <input class="form-check-input" type="checkbox" id="isactive">
                                        </div>
                                    </div>
                                    <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12">
                                        <label class="form-label">Status</label>
                                        <br />
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="status" id="inlineRadio5" value="Male">
                                            <label class="form-check-label" for="inlineRadio5">Permanent</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="status" id="inlineRadio6" value="Female">
                                            <label class="form-check-label" for="inlineRadio6">Temporary</label>
                                        </div>

                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="status" id="inlineRadio7" value="Male">
                                            <label class="form-check-label" for="inlineRadio7">Part time</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="status" id="inlineRadio8" value="Female">
                                            <label class="form-check-label" for="inlineRadio8">Contract</label>
                                        </div>
                                    </div>

                                </div>
                                <div class="divider text-start-center divider-primary">
                                    <div class="divider-text fw-bold">Personal Documents Info</div>
                                </div>
                                <div class="row g-3 mb-5">
                                    <div class="mb-3">
                                        <label for="personaldocs" class="form-label">Upload Personal Documents</label>
                                        <input class="form-control" type="file" id="personaldocs" multiple="" name="files" data-title="EmpPersonalDocs">
                                    </div>
                                </div>
                                <div class="row">

                                    <div class="col-12 text-end p-4">
                                        <button type="submit" class="btn btn-primary waves-effect waves-light" id="btnAddEmployee">
                                            <span class="tf-icons mdi mdi-checkbox-marked-circle-outline me-1"></span>
                                            Add
                                        </button>
                                        <button type="button" class="btn btn-success waves-effect waves-light d-none" id="btnUpdateEmployee">
                                            <span class="tf-icons mdi mdi-checkbox-marked-circle-outline me-1"></span>
                                            Update
                                        </button>
                                        <button type="button" class="btn btn-secondary waves-effect waves-light d-none" id="btnCancelEdit">
                                            Cancel
                                        </button>
                                    </div>

                                </div>
                            </form>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>
<input type="hidden" id="usernametoedit" />
<input type="hidden" id="hiddenempId" />

<div class="modal fade" id="addContactInfo" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Add Contact Info</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-5">
                    <div class="col-md-6">
                        <label class="form-label">Phone No</label>
                        <input type="text" class="form-control" placeholder="+92 300 1234567" id="phone1addmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone No (Alternate)</label>
                        <input type="text" class="form-control" placeholder="+92 300 7654321" id="phone2addmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="john@example.com" id="email1addmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email (Alternate)</label>
                        <input type="email" class="form-control" placeholder="john@example.com" id="email2addmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Address</label>
                        <input type="text" class="form-control" placeholder="Street Address" id="addressaddmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Province</label>
                        <input type="text" class="form-control" placeholder="Punjab" id="provenceaddmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" placeholder="Karachi" id="cityaddmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Country</label>
                        <input type="text" class="form-control" placeholder="Pakistan" id="countryaddmore">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Is Active</label>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="isactiveaddMore">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary waves-effect" data-bs-dismiss="modal">
                    Close
                </button>
                <button type="button" class="btn btn-primary waves-effect waves-light" onclick="addContactInfo()">Add</button>
            </div>
        </div>
