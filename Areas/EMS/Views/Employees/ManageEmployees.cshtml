</div>

<div class="modal fade" id="addJobInfo" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Add Job Info</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-5">
                    <div class="col-md-6">
                        <label class="form-label">Department</label>
                        <select id="departmentsListaddmore" class="form-select form-select-lg"></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Designation</label>
                        <input type="text" class="form-control" placeholder="Manager" id="designationaddmore">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Joining Date</label>
                        <input type="date" class="form-control" id="joiningDateaddmore">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Salary</label>
                        <input type="text" class="form-control" placeholder="50,000" id="salaryaddmore">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Shift</label><br />
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="shiftaddmore" value="Day">
                            <label class="form-check-label">Day</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="shiftaddmore" value="Night">
                            <label class="form-check-label">Night</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Shift Timings</label>
                        <input type="text" class="form-control" placeholder="9:00am to 5:00pm" id="shifttimmingsaddmore">
                    </div>

                    <div class="col-md-6">
                        <label for="formFileCVaddmore" class="form-label">Upload CV</label>
                        <input class="form-control" type="file" id="formFileCVaddmore" name="files" data-title="EmpCV">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Is Active</label>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="isactiveaddmore">
                        </div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Status</label><br />
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="statusaddmore" value="Permanent">
                            <label class="form-check-label">Permanent</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="statusaddmore" value="Temporary">
                            <label class="form-check-label">Temporary</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="statusaddmore" value="PartTime">
                            <label class="form-check-label">Part Time</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="statusaddmore" value="Contract">
                            <label class="form-check-label">Contract</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary waves-effect" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary waves-effect waves-light" onclick="addJobInfo()">Add</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addCredentialsInfo" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="exampleModalLabel3">Add Credentials Info</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-5">
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" placeholder="john.doe" id="usernameaddmore">
                    </div>
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" placeholder="password" id="passwordaddmore">
                    </div>
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                        <label class="form-label">My Role</label>
                        <select id="myrolesListaddmore" class="form-select form-select-lg"></select>
                    </div>
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                        <label class="form-label">Roles Under Me</label>
                        <select id="rolesListundermeaddmore" class="form-select form-select-lg" multiple></select>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary waves-effect" data-bs-dismiss="modal">
                    Close
                </button>
                <button type="button" class="btn btn-primary waves-effect waves-light" onclick="addCredentialsInfo()">Add</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addFilesInfo" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="exampleModalLabel3">Upload Files</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-5">
                    <div class="col-md-6 mb-3">
                        <label for="personaldocs" class="form-label">Upload Files</label>
                        <input class="form-control" type="file" id="personaldocsaddmore" multiple="" name="files">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="personaldocs" class="form-label">Type</label>
                        <select class="form-control" id="titleaddmore">
                            <option value="EmpPersonalDocs">Employee Personal Docs</option>
                            <option value="EmpCV">Employee CV</option>
                            
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary waves-effect" data-bs-dismiss="modal">
                    Close
                </button>
                <button type="button" class="btn btn-primary waves-effect waves-light" onclick="addFiles()">Upload</button>
            </div>
        </div>
    </div>
