            // ... rest of your existing logic ...
            let participantsHtml = "";
            if (ParticipantsJson && ParticipantsJson !== "[]") {
                try {
                    let users = JSON.parse(ParticipantsJson);
                    // ... (rest of your logic for building participantsHtml) ...
                    if (users.length > 0) {
                        participantsHtml = `
