    function initRolesDropdown($roledropdown = null, $rolesundermedropdown = null, selectedRoleId = null, selectedRolesUnderMe = null) {
    $.ajax({
        url: '@Url.Action("GetRolesDropdown", "Rights", new { area = "Admin" })',
        type: 'GET',
        dataType: 'json',
        success: function (roles) {
            $roledropdown.empty().append(`<option value="">Select Role</option>`);
            $rolesundermedropdown.empty().append(`<option value="">Select Roles Under Me</option>`);;

            $.each(roles, function (i, role) {
                $roledropdown.append(`<option value="${role.Id}">${role.Name}</option>`);
                $rolesundermedropdown.append(`<option value="${role.Id}">${role.Name}</option>`);
            });

            // Pre-select values if editing
            if (selectedRoleId) {
                $roledropdown.val(selectedRoleId).trigger('change');
            }
            if (selectedRolesUnderMe && selectedRolesUnderMe.length > 0) {
                $rolesundermedropdown.val(selectedRolesUnderMe).trigger('change');
            }

            $roledropdown.select2({
                placeholder: "-- Select Role --",
                allowClear: true,
                width: '100%'
            });

            $rolesundermedropdown.select2({
                placeholder: "-- Select Roles Under Me --",
                allowClear: true,
                width: '100%'
            });


            if ($roledropdown.is($("#myrolesListaddmore"))) {
                $roledropdown.select2({
                    placeholder: "-- Select Role --",
                    allowClear: true,
                    width: '100%',
                    dropdownParent: $("#addCredentialsInfo")
                });
            }

            if ($rolesundermedropdown.is($("#rolesListundermeaddmore"))) {
                $rolesundermedropdown.select2({
                    placeholder: "-- Select Roles Under Me--",
                    allowClear: true,
                    width: '100%',
                    dropdownParent: $("#addCredentialsInfo")
                });
            }
        },
        error: function (xhr, status, error) {
            console.error("Error loading roles:", error);
            alert("Failed to load roles.");
        }
    });
}


