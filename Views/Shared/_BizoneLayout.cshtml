                   // Hide the Rooms UI
                   $('#chatbotRooms').hide();

                   // Show the Area UI (the container)
                   $('#chatbotArea').show().addClass('show');

                   // Show Selection specifically, hide Chat window
                   $('#userSelectList').show();

                   $('#loadChat, #chatfooter').hide();
