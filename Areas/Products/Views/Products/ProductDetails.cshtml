function updateVariant() {
    let form = $("#editVariantForm");

    // Manual handling for checkboxes to ensure boolean values
    let variantData = {
        Id: form.find('input[name="Id"]').val(),
        ProductId: form.find('input[name="ProductId"]').val(),
        Colour: form.find('input[name="Colour"]').val(),
        Size: form.find('input[name="Size"]').val(),
        Material: form.find('input[name="Material"]').val(),
        Price: form.find('input[name="Price"]').val(),
        StockQuantity: form.find('input[name="StockQuantity"]').val(),
        DiscountRate: form.find('input[name="DiscountRate"]').val(),
        IsAvailable: form.find('#vEditAvailable').is(':checked'),
        OnSale: form.find('#vEditOnSale').is(':checked')
    };

    // 2. Validation
    if (!variantData.Price || variantData.Price.trim() === '') {
        alert("Price is required");
        return;
    }
    if (!variantData.StockQuantity || variantData.StockQuantity.trim() === '') {
        alert("Stock Quantity is required");
        return;
    }

    $.ajax({
        url: '@Url.Action("UpdateVariantDetails", "Products")',
        type: 'POST',
        data: variantData,
        success: function (res) {
            if (res.success) {
                alert("Variant updated successfully!");
                $("#genericModal").modal('hide');
                location.reload(); // Refresh to see changes
            } else {
                alert("Update failed: " + res.message);
            }
        }
    });
        }

