@section scripts{
    <script>
        $(document).ready(function () {

            $("#btnAddRights").click(function () {

                var selectedRights = [];

                $("input[type=checkbox]:checked:not(:disabled)").each(function () {

                    if (this.id !== "chkallRights") {

                        var $checkbox = $(this);

                        var details = $checkbox
                            .closest(".form-check")
                            .find("label .text-muted")
                            .text()
                            .trim();

                        selectedRights.push({
                            Type: $checkbox.attr("name"), // QueriesRights
                            Name: $checkbox.val(),        // QUERY_ASSIGN_TEAM
                            Details: details              // Assign queries to team
                        });
                    }
                });

                console.log(selectedRights);



                if (selectedRights.length === 0) {
                    alert("Please select at least one right.");
                    return;
                }

                $.ajax({
                    url: '@Url.Action("SaveRights", "Rights", new { area = "Admin"})',
                    type: "POST",
                    data: JSON.stringify({ rights: selectedRights, mode: 1 }),
                    contentType: "application/json; charset=utf-8",
                    success: function (res) {
                        alert("Rights saved successfully!");
                        location.reload();
                    },
                    error: function (err) {
                        alert("Error while saving rights.");
                    }
                });

            });
           $("#btnUpdateRights").click(function () {
    var selectedUpdatedRights = [];

    // FIX: Don't filter by :disabled, filter by data-id > 0
    // because we unlocked them to edit them!
    $("input[type=checkbox]").each(function () {
        var $checkbox = $(this);
        var id = $checkbox.data("id");

        // Only process rights that already exist (Id > 0)
        // and ignore the 'Select All' / 'Update' toggle buttons
        if (id > 0 && $checkbox.is(":checked") && this.id !== "chkallRights" && this.id !== "chkUpdateRights") {

            var details = $checkbox
                .closest(".form-check")
                .find("label .text-muted")
                .text()
                .trim();

            selectedUpdatedRights.push({
                Id: id,
                Type: $checkbox.attr("name"),
                Name: $checkbox.val(),
                Details: details,
                IsActive: $checkbox.is(":checked") // Pass the new state (checked or unchecked)
            });
        }
    });

    if (selectedUpdatedRights.length === 0) {
        alert("No existing rights found to update.");
        return;
               }

               debugger;

    $.ajax({
        url: '@Url.Action("SaveRights", "Rights", new { area = "Admin"})',
        type: "POST",
        data: JSON.stringify({ rights: selectedUpdatedRights, mode: 3 }),
        contentType: "application/json; charset=utf-8",
        success: function (res) {
            alert("Rights Updated successfully!");
            location.reload();
        },
        error: function (err) {
            alert("Error while saving rights.");
        }
    });
});
  });



    $(document).ready(function () {
        // Fetch rights from DB
        $.ajax({
            url: '@Url.Action("GetRights", "Rights", new { area = "Admin"})',
            type: "GET",
            success: function (rights) {
                if (rights && rights.length > 0) {
                    rights.forEach(function (dbRight) {

                        $("input[type=checkbox][value='" + dbRight.Name + "']")
                            .prop("checked", true)   // check it
                            .prop("disabled", true)
                            .attr("data-id", dbRight.Id); //set id
                    });
                }
            },
            error: function () {
                console.log("Failed to load rights from DB.");
            }
        });

      $("#chkUpdateRights").change(function () {
    var isUpdateMode = $(this).is(":checked");
    var $rightsCheckboxes = $("input[type=checkbox]").not("#chkallRights, #chkUpdateRights");

    if (isUpdateMode) {
        $.ajax({
            url: '@Url.Action("GetRights", "Rights", new { area = "Admin"})',
            type: "GET",
            success: function (dbRights) {
                var updateCount = 0; // Track how many need updates

                $rightsCheckboxes.each(function () {
                    var $checkbox = $(this);
                    var id = $checkbox.data("id");

                    if (id > 0) {
                        var dbRecord = dbRights.find(r => r.Id === id);
                        if (dbRecord) {
                            var uiName = $checkbox.val();
                            var uitype = $checkbox.attr("name");
                            var uiDetails = $checkbox.closest(".form-check").find("label .text-muted").text().trim();

                            // Compare HTML with DB
                            if (uiName !== dbRecord.Name || uiDetails !== dbRecord.Details || uitype !== dbRecord.Type) {
                                // MISMATCH: Enable and keep checked for update
                                $checkbox.prop("disabled", false).prop("checked", true);
                                $checkbox.closest(".form-check").addClass("border-danger").css("border-width", "2px");
                                updateCount++;
                            } else {
                                // MATCH: Lock it
                                $checkbox.prop("disabled", true).prop("checked", true);
                                $checkbox.closest(".form-check").removeClass("border-danger");
                            }
                        }
                    } else {
                        // Not in DB yet
                        $checkbox.prop("disabled", true).prop("checked", false);
                    }
                });

                // Check if any updates were actually found
                if (updateCount === 0) {
                    alert("There are no rights to be updated. All UI labels match the Database.");
                    $("#chkUpdateRights").prop("checked", false).change(); // Toggle back off
                    return;
                }

                $("#btnUpdateRights").show();
                $("#btnCancelUpdateRights").show();
                $("#btnAddRights").hide();
            },
            error: function () {
                alert("Failed to sync with Database.");
                $("#chkUpdateRights").prop("checked", false);
            }
        });
    } else {
        // RESET UI: Lock everything back to default view state
        $rightsCheckboxes.each(function () {
            $(this).closest(".form-check").removeClass("border-danger").css("border-width", "1px");
            if ($(this).data("id") > 0) {
                $(this).prop("disabled", true).prop("checked", true);
            } else {
                $(this).prop("disabled", false).prop("checked", false);
            }
        });
        $("#btnUpdateRights").hide();
        $("#btnCancelUpdateRights").hide();
        $("#btnAddRights").show();
    }
});
            // 3. Select All Logic (Bonus: keeps everything synced)
            $("#chkallRights").change(function () {
                var isChecked = $(this).is(":checked");
                // Only toggle checkboxes that are NOT currently disabled
                $("input[type=checkbox]:not(:disabled)").not("#chkallRights, #chkUpdateRights")
                    .prop("checked", isChecked);
            });
        });
    </script>
}

