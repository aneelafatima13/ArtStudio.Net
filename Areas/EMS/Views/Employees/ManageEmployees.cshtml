// --- Update Job Info ---
$(document).on("click", "#jobInfoupdatebtn", function (e) {
    e.preventDefault();
    debugger;

    let jobId = $(this).data("id");

    let model = {
        JobId: jobId,
        DepartmentId: $("#Departmentedit").val(),
        Designation: $("#Designationedit").val(),
        JoiningDate: $("#JoiningDateedit").val(),
        Salary: $("#Salaryedit").val(),
        Status: $("#Statusedit").val(),
        Shift: $("#Shiftedit").val(),
        ShiftTiming: $("#ShiftTimingedit").val(),
        IsActive: $("input[name='JobIsActiveedit']:checked").val(),
        Username: $('#usernametoedit').val(),
        Files: []
    };

    let filePromises = [];

    // Handle CV file upload
    $("input[type=file][id=uploadCVedit]").each(function () {
        let title = $(this).data("title") || "EmpCV";
        let files = $(this)[0].files;
        let fileid = $(this).data("id");

        for (let i = 0; i < files.length; i++) {
            let file = files[i];

            let promise = new Promise((resolve) => {
                let reader = new FileReader();
                reader.onload = function (e) {
                    let base64String = e.target.result.split(',')[1];
                    model.Files.push({
                        FileId: fileid,
                        FileName: file.name,
                        FileTitle: title,
                        FileType: file.type,
                        FileBytes: base64String
                    });
                    resolve();
                };
                reader.readAsDataURL(file);
            });

            filePromises.push(promise);
        }
    });

    // After reading files
    Promise.all(filePromises).then(function () {
        $.ajax({
            url: '@Url.Action("EmployeeJobInfoUpdate", "Employees", new { area = "EMS" })',
            type: 'POST',
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(model),
            success: function (res) {
                if (res.success) {
                    alert("Job info updated successfully!");
                    appendEdittabwithdata(jobId); // reload updated data
                } else {
                    alert("Error: " + res.message);
                }
            },
            error: function (xhr, status, error) {
                console.error("Error:", error);
                alert("Error while updating job info.");
            }
        });
    });
});

