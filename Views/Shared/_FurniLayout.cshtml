    <button type="button" class="floating-msg-btn" data-bs-toggle="modal" data-bs-target="#contactModal">
        <i class="fas fa-comment-dots"></i>
    </button>

    <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="contactModalLabel">Art Studio Support</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body position-relative">
                    <div id="loader" style="display:none; position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); z-index: 10;">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>

                    <div id="chatHistory" style="height: 300px; overflow-y: auto; overflow-x: hidden; padding: 10px; background: #f9f9f9; border-radius: 8px;"></div>

                    <div id="chatStatus" class="alert alert-success d-none mt-2">Message sent successfully!</div>
                </div>

                <div class="modal-footer d-block border-top-0">
                    <form id="supportForm" enctype="multipart/form-data">
                        <div class="input-group">
                            <label class="input-group-text bg-light border-end-0" style="cursor: pointer;" for="fileAttach">
                                <i class="fas fa-paperclip text-muted"></i>
                                <input type="file" id="fileAttach" name="attachments" multiple hidden>
                            </label>

                            <textarea class="form-control border-start-0" id="userMessage" name="message" rows="1" placeholder="Type your message..." required style="resize: none;"></textarea>

                            <button class="btn btn-primary" type="submit" id="btnSendSupport">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                        <small id="fileNameDisplay" class="text-muted d-block mt-1" style="font-size: 10px;"></small>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script>
        $(document).ready(function () {
    // Show selected filename when attached
    $('#fileAttach').on('change', function() {
        var fileName = $(this).val().split('\\').pop();
        $('#fileNameDisplay').text(fileName ? "Attached: " + fileName : "");
    });

    $('#supportForm').on('submit', function (e) {
        e.preventDefault();

        var formData = new FormData(this);
        const replyId = $('.msg-selector:checked').data('id');
        if (replyId) {
            formData.append("replyToId", replyId);
        }
        var $btn = $('#btnSendSupport');
        var $loader = $('#loader');

        // UI Feedback
        $btn.prop('disabled', true);
        $loader.show();

        $.ajax({
            url: '@Url.Action("SendMessage", "Chats", new { area = "EndUser" })',
            type: 'POST',
            data: formData,
            processData: false, // Required for FormData
            contentType: false, // Required for FormData
            success: function (response) {
                if (response.success) {
                    $('#chatStatus').removeClass('d-none').fadeIn().delay(3000).fadeOut();
                    $('#supportForm')[0].reset();
                    $('#fileNameDisplay').text("");

                    loadChatHistory();
                } else {
                    alert("Error: " + response.message);
                }
            },
            error: function () {
                alert("Something went wrong. Please try again.");
            },
            complete: function() {
                $btn.prop('disabled', false);
                $loader.hide();
            }
        });
    });
});
        $('#contactModal').on('shown.bs.modal', function () {
            $('#userMessage').trigger('focus');
            loadChatHistory();
        });



    function loadChatHistory() {
    $.get('@Url.Action("GetChatHistory", "Chats", new { area = "EndUser" })', function (res) {
        let html = '';

        if (res.data && res.data.length > 0) {
            res.data.forEach(chat => {
                const isFromAdmin = chat.IsFromAdmin;

                // CUSTOMER PERSPECTIVE:
                // Admin replies = Left (Start), My messages = Right (End)
                const alignmentClass = isFromAdmin ? 'justify-content-start' : 'justify-content-end';
                const bubbleBg = isFromAdmin ? '#f1f1f1' : '#3b5d50'; // Grey for Admin, Green for Me
                const textColor = isFromAdmin ? '#333' : '#fff';

                // "Seen" Logic: If any admin has seen it, show double check
                let statusIcon = '';
                if (!isFromAdmin) {
                    // Even if 5 admins saw it, we just care that the string 'SeenByAdmins' is not empty
                    if (chat.SeenByAdmins && chat.SeenByAdmins.trim().length > 0) {
                        statusIcon = `<span class="ms-1 text-info" title="Seen by Support"><i class="fas fa-check-double"></i></span>`;
                    } else {
                        statusIcon = `<span class="ms-1 text-muted" title="Sent"><i class="fas fa-check"></i></span>`;
                    }
                }

                html += `
                <div class="d-flex ${alignmentClass} mb-3">
                    <div class="chat-bubble shadow-sm" style="max-width: 80%; padding: 12px; border-radius: 15px; background:${bubbleBg}; color:${textColor}; position: relative;">

                        ${chat.MessageBody ? `<div class="msg-text" style="font-size: 14px;">${chat.MessageBody}</div>` : ''}

                        ${chat.Attachments && chat.Attachments.length > 0 ? `
                            <div class="attachment-area mt-2 pt-2 border-top" style="border-color: rgba(255,255,255,0.2) !important;">
                                ${chat.Attachments.map(file => `
                                    <a href="${file.AttachmentPath}" target="_blank" class="d-block small text-truncate ${isFromAdmin ? 'text-primary' : 'text-white'}" style="text-decoration:none; font-size: 11px;">
                                        <i class="fas fa-paperclip me-1"></i> ${file.FileName}
                                    </a>
                                `).join('')}
                            </div>
                        ` : ''}

                        <div class="chat-time text-end mt-1" style="font-size: 10px; opacity: 0.8;">
                            ${chat.createatString} ${statusIcon}
                        </div>
                    </div>
                </div>`;
            });
        } else {
            html = '<div class="text-center text-muted mt-5"><p>No messages yet. Send a message to start chatting!</p></div>';
        }

        $('#chatHistory').html(html);

        // Ensure the scroll stays at the bottom for the newest messages
        var chatHistoryDiv = $('#chatHistory');
        chatHistoryDiv.scrollTop(chatHistoryDiv[0].scrollHeight);
    });
}

        $(document).on('change', '.msg-selector', function () {
            if ($(this).is(':checked')) {
                // Uncheck all other checkboxes except the one just clicked
                $('.msg-selector').not(this).prop('checked', false);

                // Get the single ID
                const selectedId = $(this).data('id');
                console.log("Active Message ID:", selectedId);
            }
        });
        $(document).ready(function () {
            loadChatHistory();
    // 1. Initial UI check from Cookies
    const savedCurrency = getCookie("SelectedCurrency");
    if (savedCurrency) {
        $("#currentCurrency").text(savedCurrency);
    }

    // 2. Fetch Currency List via AJAX
    $.ajax({
        url: '@Url.Action("GetCurrencyDropdown", "Shop", new { area = "Products" })',
        type: 'GET', // or POST depending on your Controller attribute
        data: { mode: 6 },
        success: function (res) {
            debugger;
            if (res && res.data) {
                let dropdownHtml = '';

                // Always add PKR as the first/default option
                dropdownHtml += `<li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center"
                       href="javascript:void(0);" onclick="updateCurrency('PKR', 'Rs.', 1)">
                       PKR <span>(Rs.)</span>
                    </a>
                </li>`;

                // Map through database results
                res.data.forEach(item => {
                    debugger;
                    if (item.CurrencyType !== 'PKR') {
                        dropdownHtml += `<li>
                            <a class="dropdown-item d-flex justify-content-between align-items-center"
                               href="javascript:void(0);"
                               onclick="updateCurrency('${item.CurrencyType}', '${item.CurrencySymbol}', ${item.ExchangeRate})">
                               ${item.CurrencyType} <span>(${item.CurrencySymbol})</span>
                            </a>
                        </li>`;
                    }
                });

                $("#currencyDropdownList").html(dropdownHtml);
            }
        },
        error: function (err) {
            console.error("Failed to load currencies:", err);
        }
    });
});
        function updateCurrency(code, symbol, rate) {
            const d = new Date();
            d.setTime(d.getTime() + (30 * 24 * 60 * 60 * 1000));
            const expires = "expires=" + d.toUTCString() + ";path=/;SameSite=Lax";

            // Store all pieces of info in cookies
            document.cookie = "SelectedCurrency=" + code + ";" + expires;
            document.cookie = "SelectedSymbol=" + symbol + ";" + expires;
            document.cookie = "SelectedRate=" + rate + ";" + expires;

            // Refresh page to apply changes
            location.reload();
        }

        // Helper to get cookie value
        function getCookie(name) {
            let value = "; " + document.cookie;
            let parts = value.split("; " + name + "=");
            if (parts.length === 2) return parts.pop().split(";").shift();
        }
        $(document).ready(function () {
            // 1. Get the current URL path and clean it (remove trailing slashes)
            var currentPath = window.location.pathname.toLowerCase();
            if (currentPath.length > 1 && currentPath.endsWith('/')) {
                currentPath = currentPath.slice(0, -1);
            }

            // 2. Loop through each link in your navbar
            $('.custom-navbar-nav .nav-link').each(function () {
                var linkHref = $(this).attr('href').toLowerCase();

                // 3. Match logic: exact match OR current path starts with this link (for sub-pages)
                if (currentPath === linkHref || (linkHref !== "/" && currentPath.startsWith(linkHref))) {

                    // Remove 'active' from all siblings
                    $('.custom-navbar-nav li').removeClass('active');

                    // Add 'active' to the parent <li> of the current <a>
                    $(this).closest('li').addClass('active');
                }
            });
        });
    </script>
    <script src="@Url.Content("~/FurniAssets/js/bootstrap.bundle.min.js")"></script>
    <script src="@Url.Content("~/FurniAssets/js/tiny-slider.js")"></script>
    <script src="@Url.Content("~/FurniAssets/js/custom.js")"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    @RenderSection("scripts", required: false)
</body>

