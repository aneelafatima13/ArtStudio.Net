                 transition: background-color 0.2s;"
          onmouseover="this.style.backgroundColor='#dee2e6'"
          onmouseout="this.style.backgroundColor='#e9ecef'">
        <i class="bi bi-x" style="font-size: 18px; color: #6c757d; line-height: 1;"></i>
    </span>
</li>
        <div style="max-height: 200px; overflow-y: auto;">
            ${users.map(u => `<li><a class="dropdown-item py-2" href="javascript:void(0)"><i class="bi bi-person me-2"></i>${u.Username}</a></li>`).join('')}
        </div>
