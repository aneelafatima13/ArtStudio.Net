
@{
    ViewBag.Title = "AboutUs";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}

<!-- Start Hero Section -->
<div class="hero">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div>
                    <h1>Where Imagination Meets Craftsmanship</h1>
                    <p class="mb-4">
                        From the fluid grace of oil paintings to the modern brilliance of resin art and custom sketches,
                        we master every medium to bring your vision to life. At <strong>ArtNest</strong>, we craft
                        bespoke textures, wood art, and interior masterpieces designed specifically for your space.
                    </p>
                    <p>
                        <a href="@Url.Action("Shop", "LocalHome", new { area = "EndUser" })" class="btn btn-secondary me-2">Explore Gallery</a>
                        <a href="@Url.Action("CustomDesigns", "LocalHome", new { area = "EndUser" })" class="btn btn-white-outline">Request Custom Design</a>
                    </p>
               
                </div>
            </div>
           
        </div>
