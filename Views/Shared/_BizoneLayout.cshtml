                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-file-document-edit-outline"></i>
                                <div>Manage Quotations</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage POs & Generate Invoices">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-file-sign"></i>
                                <div>Manage POs</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage Invoices & Generate Receipts">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-credit-card-outline"></i>
                                <div>Manage Invoices</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage Receipts">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-receipt-outline"></i>
                                <div>Manage Receipts</div>
                            </a>
                        </li>

