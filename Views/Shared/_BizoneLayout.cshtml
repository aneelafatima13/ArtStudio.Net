              $(document).ready(function() {
    // Attach directly to the ID since it's already in the DOM
    $('#btnStartSelectedChat').on('click', function (e) {
        e.preventDefault();
        e.stopPropagation(); // Prevents the click from bubbling to parent divs

        console.log("Click detected!");

        var selectedUsers = [];
        $('.user-checkbox:checked').each(function () {
            selectedUsers.push({
                Id: $(this).val(),
                Username: $(this).data('name')
            });
        });

        if (selectedUsers.length === 0) {
            alert("Select users first");
            return;
        }

        // Logic for room creation
        var myId = "@LoginUser.EmpId";
        selectedUsers.push({ Id: myId, Username: "Me" });

        let roomId = (selectedUsers.length === 2)
            ? "SUser_" + selectedUsers[0].Id + "_" + myId
            : "TeamByMe_" + selectedUsers.map(u => u.Id).join('_');

        let title = (selectedUsers.length === 2) ? selectedUsers[0].Username : "TeamByMe";

        let encoded = btoa(unescape(encodeURIComponent(JSON.stringify(selectedUsers))));

        // Hide selection, show chat
        $('#userSelectList').hide();
        $('#userslistfooter').hide();

        openConversation(roomId, title, encoded);
    });
});
               $('#btnSend').on('click', function () {
    sendMessage();
});


function sendMessage() {
    var message = $('#msgInput').val().trim();

    // 1. Validation Check: Ensure message and room are selected
    if (message === "") {
        alert("Please enter a message.");
        return;
    }
    if (currentRoomId === "") {
        alert("Please select a chat room first.");
        return;
    }

    // 2. Connection Check: Ensure SignalR is actually connected
    if ($.connection.hub.state !== $.signalR.connectionState.connected) {
        alert("You are currently offline. Trying to reconnect...");
        $.connection.hub.start(); // Attempt to reconnect
        return;
    }

    try {
        // 3. Send Message
        chat.server.sendMessage("@LoginUser.EmpId", "@LoginUser.EmpUsername", message, currentRoomId)
            .done(function () {
                // Success: Clear input and focus
                $('#msgInput').val('').focus();
                // Optional: scroll to bottom of chat
                var chatDiv = document.getElementById("loadChat");
                chatDiv.scrollTop = chatDiv.scrollHeight;
            })
            .fail(function (error) {
                // 4. Server-Side Failure (Hub error)
                console.error("SignalR Error: " + error);
                alert("Message failed to send. Please try again.");
            });
    } catch (err) {
        // 5. Catch-all for unexpected JS errors
        alert("An unexpected error occurred while sending.");
    }
}

   });

        function openConversation(roomId, title, encodedParticipants = "") {
