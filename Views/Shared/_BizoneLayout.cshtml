                                <div>Manage Vendors</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage Quotations & Generate POs">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-file-document-multiple-outline"></i>
                                <div>Manage Quotations</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage POs & Upload Invoices">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-file-send-outline"></i>
                                <div>Manage POs</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage Invoices & Upload Receipts">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-credit-card-outline"></i>
                                <div>Manage Invoices</div>
                            </a>
                        </li>
                        <li class="menu-item" data-bs-toggle="tooltip"
                            data-bs-placement="right"
                            title="Manage Receipts">
                            <a href="#" class="menu-link">
                                <i class="menu-icon tf-icons mdi mdi-receipt-text-outline"></i>
                                <div>Manage Receipts</div>
                            </a>
                        </li>
                    </ul>
