        $(document).on("click", "#personalInfoupdatebtn", function (e) {
    e.preventDefault(); // prevent default form submit
    debugger;

    let empId = $(this).data("id"); // employee Id from button

    let model = {
        Id: empId,
        FirstName: $("#firstNameedit").val(),
        LastName: $("#lastNameedit").val(),
        FullName: $("#FullNameedit").val(),
        FatherName: $("#FatherNameedit").val(),
        CNIC: $("#CNICedit").val(),
        DateOfBirth: $("#DOBedit").val(),
        Age: $("#Ageedit").val(),
        Religion: $("#Religionedit").val(),
        Nationality: $("#Nationalityedit").val(),
        Gender: $("input[name='Genderedit']:checked").val(),
        MaritalStatus: $("input[name='MaritalStatusedit']:checked").val(),
        IsActive: $("input[name='IsActiveedit']:checked").val(),
        Username: $('#usernametoedit').val(),
        Files: []
    };

    let filePromises = [];

    // Handle file upload (if new image selected)
    $("input[type=file][id=uploadImageedit]").each(function () {
        let title = $(this).data("title") || "EmpImage";
        let files = $(this)[0].files;
        let fileid = $(this).data("id");

        for (let i = 0; i < files.length; i++) {
            let file = files[i];

            let promise = new Promise((resolve) => {
                let reader = new FileReader();
                reader.onload = function (e) {
                    let base64String = e.target.result.split(',')[1];
                    model.Files.push({
                        FileId: fileid,
                        FileName: file.name,
                        FileTitle: title,
                        FileType: file.type,
                        FileBytes: base64String
                    });
                    resolve();
                };
                reader.readAsDataURL(file);
            });

            filePromises.push(promise);
        }
    });

    // Wait until all files are read
    Promise.all(filePromises).then(function () {
        $.ajax({
            url: '@Url.Action("EmployeePersonalInfoUpdate", "Employees", new { area = "EMS" })',
            type: 'POST',
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(model),
            success: function (res) {
                if (res.success) {
                    alert("Employee updated successfully!");
                    appendEdittabwithdata(empId);
                } else {
                    alert("Error: " + res.message);
                }
            },
            error: function (xhr, status, error) {
                console.error("Error:", error);
                alert("Error while updating employee.");
            }
        });
    });
        });

