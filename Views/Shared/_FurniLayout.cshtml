    <style>
        .floating-msg-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background-color: white; /* Furni Theme Green */
            color: #3b5d50;
            border-radius: 50%;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            z-index: 1050;
            transition: transform 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

            .floating-msg-btn:hover {
                transform: scale(1.1);
                background-color: #ced4da;
            }

        /* Adjusting the text area to look more like a chat bar */
        #userMessage:focus {
            box-shadow: none;
            border-color: #ced4da;
        }

        .modal-content {
            border-radius: 15px;
            overflow: hidden;
        }

        /* Styling the checkbox to match the theme */
        .msg-selector {
            cursor: pointer;
            width: 18px;
            height: 18px;
            border: 2px solid #3b5d50; /* Furni Theme Green */
        }

        .msg-selector:checked {
            background-color: #3b5d50;
            border-color: #3b5d50;
        }

        /* Ensure flex alignment for the checkbox container */
        .d-flex.align-items-center {
            display: flex;
            align-items: center;
        }
