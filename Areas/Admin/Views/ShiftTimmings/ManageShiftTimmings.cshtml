
@{
    ViewBag.Title = "ManageShiftTimmings";
    Layout = "~/Views/Shared/_BizoneLayout.cshtml";
}
<div class="container-xxl flex-grow-1 container-p-y">
    <div class="card mb-4">
        <h5 class="card-header">Set Shift Timmings</h5>
        <div class="card-body">
            <form id="form">
                <input type="hidden" id="Id" value="0" />
               
                <div class="row">
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                        <label class="form-label">Shift In</label>
                        <input class="form-control" type="time" id="shiftIn">
                    </div>

                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-6">
                        <label class="form-label">Shift Out</label>
                        <input class="form-control" type="time" id="ShiftOut">
                    </div>
                   
                    
                   
                    <div class="col-12 text-end p-4">
                        <button type="submit" class="btn btn-primary" id="btnSavetime">Add</button>
                        <button type="button" class="btn btn-secondary d-none" id="btnCanceltime">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card mb-4">
        <h5 class="card-header">List</h5>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">

                </div>
                <div class="col-md-4">
                    <input type="search" class="form-control" placeholder="Search.." id="search" />
                </div>
            </div>
            <br />
            <table id="list" class="table table-hover align-middle shadow-sm rounded">
                <thead style="background-color: #3b5d50">
                    <tr>
                        <th style="color: white">Shift In</th>
                        <th style="color: white">Shift Out</th>
                        <th style="color: white">shift Timmings</th>
                        <th style="color: white" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section scripts{
    <script>
        $(document).ready(function () {
            loadShiftList();

            // Save
            $("#form").submit(function (e) {
                e.preventDefault();
                let shiftIn = $("#shiftIn").val();   // e.g., "09:00"
                let shiftOut = $("#ShiftOut").val(); // e.g., "17:00"

                function formatAMPM(timeStr) {
                    let [hour, minute] = timeStr.split(':').map(Number);
                    let ampm = hour >= 12 ? 'PM' : 'AM';
                    hour = hour % 12;
                    if (hour === 0) hour = 12;
                    return `${hour}:${minute.toString().padStart(2, '0')} ${ampm}`;
                }

                let model = {
                    Id: $("#Id").val(),
                    ShiftIn: shiftIn,
                    ShiftOut: shiftOut,
                    ShiftTimmings: formatAMPM(shiftIn) + " to " + formatAMPM(shiftOut)
                };
                $.ajax({
                    url: '@Url.Action("SaveShift", "ShiftTimmings", new { area = "Admin"})',
                    type: 'POST',
                    data: model,
                    success: function (res) {
                        if (res.success) {
                            alert("Saved successfully");
                            table.ajax.reload();
                            $("#form")[0].reset();
                            $("#btnSavetime").text("Add");
                            $("#btnCanceltime").addClass("d-none");
                        }
                    }
                });
            });

            // Delete
            
            $(document).on("click", ".btn-delete", function () {
                let id = $(this).data("id");
                if (confirm("Are you sure you want to delete this shift?")) {
                    $.ajax({
                        url: '@Url.Action("DeleteShift", "ShiftTimmings", new { area = "Admin"})',  // Controller action
                        type: 'POST',
                        data: { id: id },
                        success: function (res) {
                            if (res.success) {
                                alert(res.message || "Deleted successfully");
                                table.ajax.reload();// reload the list
                            } else {
                                alert(res.message || "Failed to delete");
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error(error);
                            alert("Something went wrong while deleting.");
                        }
                    });
                }
            });

            // Edit
            $(document).on("click", ".btn-edit", function () {
                let id = $(this).data("id");

                $.ajax({
                    url: '@Url.Action("GetShift", "ShiftTimmings", new { area = "Admin"})',
                    type: "GET",
                    data: { id: id },
                    success: function (res) {

                        if (res && res.data) {
                            debugger;
                            let d = res.data;
                            $("#Id").val(d.Id);
                            $("#shiftIn").val(d.ShiftInString ? d.ShiftInString : "");
                            $("#ShiftOut").val(d.ShiftOutString ? d.ShiftOutString : "");
                            $("#btnSavetime").text("Update");
                            $("#btnCanceltime").removeClass("d-none");
                            $('html, body').animate({
                                scrollTop: $("#form").offset().top - 50
                            }, 500);
                        } else {
                            alert("Shift not found!");
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Error fetching shift:", error);
                        alert("Something went wrong while fetching shift data.");
                    }
                });
            });

            function formatTime(time) {
                if (!time) return "";

                // Convert to string if it's not
                let t = time.toString();

                // Handle time like "09:00:00" or "09:00"
                let parts = t.split(':');
                if (parts.length < 2) return t; // fallback

                let hours = parseInt(parts[0], 10);
                let minutes = parts[1];
                let ampm = hours >= 12 ? 'PM' : 'AM';
                hours = hours % 12 || 12; // convert 0/13-23 to 12-hour
                return hours + ':' + minutes + ' ' + ampm;
            }

            // 🔹 Cancel Edit
            $("#btnCanceltime").on("click", function () {
                $("#form")[0].reset();
                $("#Id").val(0);
                $("#btnSavetime").text("Add");
                $("#btnCanceltime").addClass("d-none");
            });

            function loadShiftList(page = 1) {

               var table = $("#list").DataTable({
    lengthChange: false,
    info: false,
    searching: false,
    processing: true,
    serverSide: true,  // ✅ enable server-side paging if you want
    ajax: {
        url: '@Url.Action("GetShifts", "ShiftTimmings", new { area = "Admin"})',
        type: "GET",
        data: function (d) {
            d.page = (d.start / d.length) + 1;   // page index
            d.pageSize = d.length;              // page size
            d.search = $("#search").val();      // optional search filter
        }
    },
    columns: [
        {
            data: "ShiftInString"
        },
        {
            data: "ShiftOutString"
        },
        { data: "ShiftTimmings" },
        {
            data: "Id",
            className: "text-center",
            render: function (data, type, row) {
                return `
                    <button type="button" class="btn btn-sm btn-primary btn-edit" data-id="${data}">
                        <span class="mdi mdi-pencil-outline"></span>
                    </button>
                    <button type="button" class="btn btn-sm btn-primary btn-delete" data-id="${data}">
                        <span class="mdi mdi-delete-outline"></span>
                    </button>
                `;
            }
        }
    ]
});

            }
        });

    </script>
    }