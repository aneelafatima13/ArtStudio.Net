            let ParticipantsJson = "[]";
            if (encodedParticipants && encodedParticipants !== "") {
                try {
                    // atob() decodes the base-64 string
                    ParticipantsJson = decodeURIComponent(escape(atob(encodedParticipants)));
                } catch (e) {
                    console.error("Base64 Decode Error:", e);
                }
            }

            // Hide Rooms, Show Area
            $('#chatbotRooms').hide().removeClass('show');
            $('#chatbotArea').show().addClass('show');
            $('#loadChat, #chatfooter').show();
