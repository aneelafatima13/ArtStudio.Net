@{
    ViewBag.Title = "Orders";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}

@if (ViewBag.ReturnType == 1)
{
    <div class="container">
        <div class="alert alert-success mt-4">
            Your Order has been placed successfully!
        </div>
        </div>
        }

        <div class="untree_co-section before-footer-section">
            <div class="container">
                <div id="OrdersList">
                </div>

                <div class="row mt-5">
                    <div class="col-12 text-center">
                        <div id="pagination-controls" class="btn-group">
                            <button class="btn btn-outline-black btn-sm" id="prevPage" onclick="changePage(-1)">Previous</button>
                            <span class="btn btn-sm" id="currentPageDisplay" style="pointer-events: none;">Page 1</span>
                            <button class="btn btn-outline-black btn-sm" id="nextPage" onclick="changePage(1)">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Use @ViewBag.CustomerId directly in the hidden field *@
        <input type="hidden" id="c_id" value="@ViewBag.CustomerId" />

        @section scripts{
            <script>
        var currentPage = 1;
        var pageSize = 10;

        $(document).ready(function () {
            loadOrders(currentPage);
        });

        function changePage(step) {
            currentPage += step;
            loadOrders(currentPage);
        }

      function loadOrders(page) {
    var customerId = $('#c_id').val();
    var lastOrderId = 0; // Track the previous order to handle grouping

    $.ajax({
        url: '@Url.Action("GetCustomerOrders", "Orders", new { area = "Products" })',
        type: 'GET',
        data: { customerId: customerId, pageNumber: page, pageSize: pageSize },
        beforeSend: function() {
            $('#OrdersList').html('<div class="text-center p-5"><h4>Loading your orders...</h4></div>');
        },
        success: function (response) {
            if (response.data && response.data.length > 0) {
                var html = "";

                $.each(response.data, function (key, item) {
                    var date = new Date(parseInt(item.OrderDate.substr(6)));

                    // --- GROUPING LOGIC: Start a new Card if OrderId changes ---
                    if (item.OrderId !== lastOrderId) {
                        // Close previous table and card if it's not the first record
                        if (lastOrderId !== 0) {
                            html += '</tbody></table></div></div>';
                        }

                        // Open New Card
                        html += `
                        <div class="card mb-4 shadow-sm">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-0 text-primary">Order #${item.OrderId}</h5>
                                    <small class="text-muted">Placed on: ${date.toLocaleDateString()} ${date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-info text-dark">Total: $${item.GrandTotal.toFixed(2)}</span>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Product</th>
                                            <th class="text-center">Qty</th>
                                            <th>Price</th>
                                            <th>Item Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;

                        lastOrderId = item.OrderId;
                    }

                    // --- TABLE ROWS (Items) ---
                    const imageSrc = item.ProductImage
                        ? `/Products/Shop/GetImg?path=${encodeURIComponent(item.ProductImage)}`
                        : '/FurniAssets/images/product-1.png';

                    html += `
                    <tr>
                        <td class="align-middle">
                            <div class="d-flex align-items-center">
                                <img src="${imageSrc}" class="rounded border" style="width: 50px; height: 50px; object-fit: cover; margin-right:15px;">
                                <div>
                                    <span class="d-block fw-bold text-dark">${item.ProductName}</span>
                                    <small class="text-muted">Unit Price: $${item.UnitPrice.toFixed(2)}</small>
                                </div>
                            </div>
                        </td>
                        <td class="align-middle text-center">${item.Quantity}</td>
                        <td class="align-middle font-weight-bold">$${(item.UnitPrice * item.Quantity).toFixed(2)}</td>
                        <td class="align-middle">${getItemStatusBadge(item.ItemStatus)}</td>
                    </tr>`;
                });

                // Close the very last card
                html += '</tbody></table></div></div>';

                $('#OrdersList').html(html);

                // Pagination logic
                $('#currentPageDisplay').text("Page " + page);
                $('#prevPage').prop('disabled', page === 1);
                $('#nextPage').prop('disabled', response.data.length < pageSize);
                $('#pagination-controls').show();

            } else {
                // Handle empty state
                if (page === 1) {
                    $('#OrdersList').html('<div class="alert alert-info text-center">You have no order history yet.</div>');
                    $('#pagination-controls').hide();
                }
            }
        }
    });
                }

                function getItemStatusBadge(status) {
                    // Customize these IDs based on your OrderStatusTrack table values
                    switch (status) {
                        case 1: return '<span class="badge bg-warning text-dark">Pending</span>';
                        case 2: return '<span class="badge bg-primary">Processing</span>';
                        case 3: return '<span class="badge bg-info">Shipped</span>';
                        case 4: return '<span class="badge bg-success">Delivered</span>';
                        case 5: return '<span class="badge bg-danger">Cancelled</span>';
                        default: return '<span class="badge bg-secondary">Unknown</span>';

                   }
                }
            </script>
        }
