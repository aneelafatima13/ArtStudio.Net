    <script>
        let lastAiResponse = []; // Store the array of strings

        $(document).ready(function () {
            // 1. New Suggestion Call
            $('#btnSuggest').on('click', function () {
                var userText = $('#msgInput').val().trim();
                if (userText.length < 3) {
                    alert("Type at least 3 characters for AI to help.");
                    return;
                }

                $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

                $.ajax({
                    url: '@Url.Action("GetAISuggestions", "Chat", new { area = "BizOneUsers" })',
                    type: 'POST',
                    data: { text: userText },
                    success: function (response) {
                        if (response.error) {
                            alert("AI Error: " + response.error);
                            return;
                        }

                        if (response.suggestions && response.suggestions.length > 0) {
                            // SAVE TO CACHE
                            lastAiResponse = response.suggestions;

                            // SHOW THE HISTORY BUTTON
                            $('#btnViewLast').fadeIn();

                            // SHOW THE BUBBLE
                            renderSuggestions(lastAiResponse);
                        }
                    },
                    error: function (xhr, status, error) {
                        alert("Server Error: " + error);
                    },
                    complete: function () {
                        $('#btnSuggest').prop('disabled', false).html('<i class="bi bi-stars"></i>');
                    }
                });
            });

            // 2. View Last Suggestions (The History Button)
            $('#btnViewLast').on('click', function () {
                if (lastAiResponse.length > 0) {
                    renderSuggestions(lastAiResponse);
                }
            });

            // 3. Clear suggestions when user types or sends
            $('#msgInput').on('input', function () {
                $('#aiSuggestionsWrapper').fadeOut();
            });

            $('#btnSend').on('click', function () {
                // Optional: Hide history button after sending if you want a clean slate
                // $('#btnViewLast').fadeOut();
                $('#aiSuggestionsWrapper').fadeOut();
            });
        });

        // Helper to render the bubble
        function renderSuggestions(suggestions) {
            $('#aiSuggestionsList').empty();
            suggestions.forEach((s) => {
                $('#aiSuggestionsList').append(`
            <div class="suggestion-pill" onclick="selectAiText('${s.replace(/'/g, "\\'")}')">
                ${s}
            </div>
        `);
            });
            $('#aiSuggestionsWrapper').stop(true, true).fadeIn(300);
        }

        function selectAiText(val) {
            $('#msgInput').val(val);
            $('#aiSuggestionsWrapper').fadeOut();
            $('#msgInput').focus();
        }

        // Function to append selected suggestions to the textarea
        function useSelectedSuggestions() {
            let selectedText = [];
            $('.ai-check:checked').each(function () {
                selectedText.push($(this).val());
            });

            if (selectedText.length > 0) {
                let currentMsg = $('#msgInput').val();
                // Append suggestions at the end or replace
                $('#msgInput').val(currentMsg + " " + selectedText.join(" ")).focus();
                $('#aiSuggestionsWrapper').hide();
            }
        }
        function updateMainUnreadCount() {
            $.get('@Url.Action("GetTotalUnreadCount", "Chat", new { area = "BizOneUsers" })', function (data) {
                var badge = $('#mainUnreadBadge');
                var headerText = $('#headerUnreadText');

                // 1. Update the Icon Badge
                if (data.count > 0) {
                    badge.text(data.count > 99 ? "99+" : data.count);
                    badge.show();
                } else {
                    badge.hide();
                }

                // 2. Update the Dropdown Header Message
                if (data.count > 0) {
                    headerText.text("You have " + data.count + " new message" + (data.count > 1 ? "s" : ""));
                } else {
                    headerText.text("You have no new messages");
                }
            });
        }
        function loadChatRooms() {
            debugger;
            $.ajax({
                url: '@Url.Action("GetChatGroups", "Chat", new { area = "BizOneUsers" })',
                type: 'GET',
                cache: false, // Prevents the browser from showing old data
                success: function (groups) {
                    $("#ChatRoomsList").empty();

                    if (!groups || groups.length === 0) {
                        $("#ChatRoomsList").html('<li class="p-3 text-center text-muted">No conversations yet</li>');
                        return;
                    }

                    let listHtml = "";
                    groups.forEach(g => {
                        // Determine Subtitle scope
                        const typeMap = {
                            'Leading': 'My Team',
                            'Member': 'Working Teams',
                            'Private': 'Private Chat',
                            'Global': 'Global Group',
                            'Custom Group': 'Custom Group'
                        };
                        let subTitle = typeMap[g.Type] || 'Chat';

                        // Handle Date/Time (Backend should provide g.LastMsgDateString)
                        let displayDate = g.LastMsgDateString || "";
                        let greenDot = g.HasUnseen
                            ? `<div class="bg-success rounded-circle ms-auto mt-1" style="width: 8px; height: 8px; border: 1px solid white;"></div>`
                            : `<div style="height: 8px; margin-top: .25rem;"></div>`; // Empty space to maintain alignment
                        // Encode participants for the View Participants dropdown in openConversation
                        let encodedParticipants = "";
                        if (g.ParticipantsJson) {
                            encodedParticipants = btoa(unescape(encodeURIComponent(g.ParticipantsJson)));
                        }

                        // Unread Badge
                        let unreadBadge = g.UnreadCount > 0
                            ? `<span class="badge bg-success rounded-pill animate__animated animate__bounceIn" style="font-size: 10px;">${g.UnreadCount}</span>`
                            : "";

                        listHtml += `
<li class="message-item group-item" onclick="openConversation('${g.RoomId}', '${g.RoomName}', '${encodedParticipants}')" style="cursor:pointer;">
    <a href="javascript:void(0)" class="d-flex align-items-center p-2">
        <img src="/BizOneAssets/img/BLACK NO IMG.png" alt="" class="rounded-circle me-2" style="width:40px; height:40px; border: 1px solid #eee;">
        <div class="w-100">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0" style="font-size: 14px; color: #444; font-weight: 600;">${g.RoomName}</h4>
                <div class="text-end">
                    <small class="text-muted" style="font-size: 10px;">${displayDate}</small>

                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <p class="mb-0" style="font-size: 11px;">
                    <small class="${g.UnreadCount > 0 ? 'fw-bold text-dark' : 'text-muted'}">${subTitle}</small>
                </p>
                ${unreadBadge}
            </div>
        </div>
    </a>
</li>
<li><hr class="dropdown-divider m-0"></li>`;
                    });

                    $("#ChatRoomsList").append(listHtml);
                },
                error: function () {
                    console.error("Failed to load chat rooms.");
                }
            });
        }

        $(document).ready(function () {
            updateMainUnreadCount();

             $(document).on('click', function (e) {
                if (!$(e.target).closest('#chatbotDiv, #chatboticon').length) {
                    $('#chatbotDiv').removeClass('show');
                }
            });
        });

        var currentRoomId = "";

           $(function () {
var chat = $.connection.chatHub;

$.connection.hub.start();

               $('#chatboticon').on('click', function (e) {
                   e.preventDefault();
                   e.stopPropagation(); // Prevents Bootstrap from interfering

                   // Close other Bootstrap dropdowns manually if needed
                   $('.dropdown-menu').not('#chatbotDiv').removeClass('show');

