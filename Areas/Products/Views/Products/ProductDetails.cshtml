      function addNewVariant() {
    let productId = $("#productId").val();
    let form = $("#addMoreVariantForm");

    // --- 1. VALIDATION LOGIC ---
    let price = form.find('input[name="Price"]').val();
    let stock = form.find('input[name="StockQuantity"]').val();

    // Check for empty or non-numeric values
    if (!price || price <= 0) {
        alert("Please enter a valid Price greater than 0.");
        return; // Stop execution
    }

    if (!stock || stock === "" || parseInt(stock) < 0) {
        alert("Please enter a valid Stock Quantity (cannot be negative).");
        return; // Stop execution
    }

    // --- 2. PREPARE DATA ---
    let formData = new FormData();

    // Append Image Files
    let fileInput = $("#newVarientImages")[0];
    if (fileInput.files.length > 0) {
        for (let i = 0; i < fileInput.files.length; i++) {
            formData.append("variantImages", fileInput.files[i]);
        }
    }

    // Append Text Data
    formData.append("ProductId", productId);
    formData.append("Colour", form.find('input[name="Colour"]').val());
    formData.append("Size", form.find('input[name="Size"]').val());
    formData.append("Material", form.find('input[name="Material"]').val());
    formData.append("Price", price);
    formData.append("StockQuantity", stock);
    formData.append("DiscountRate", form.find('input[name="DiscountRate"]').val() || 0);

    // Checkboxes
    formData.append("IsAvailable", form.find('input[name="IsAvailable"]').is(':checked'));
    formData.append("OnSale", form.find('input[name="OnSale"]').is(':checked'));

    // --- 3. SUBMIT VIA AJAX ---
    $.ajax({
        url: '@Url.Action("AddVariantWithImages", "Products")',
        type: 'POST',
        data: formData,
        contentType: false,
        processData: false,
        beforeSend: function() {
            $(".btn-primary").prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving...');
        },
        success: function (res) {
            if (res.success) {
                alert("Variant added successfully!");
                $("#genericModal").modal('hide');
                location.reload();
            } else {
                alert("Error: " + res.message);
                $(".btn-primary").prop('disabled', false).html('<i class="fa-solid fa-floppy-disk me-1"></i> Save Variant');
            }
        },
        error: function () {
            alert("An error occurred during submission.");
            $(".btn-primary").prop('disabled', false).html('<i class="fa-solid fa-floppy-disk me-1"></i> Save Variant');
        }
    });
        }

    </script>
