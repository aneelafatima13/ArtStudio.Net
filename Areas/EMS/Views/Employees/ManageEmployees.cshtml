    function addFiles() {
    let empId = $("#hiddenempId").val();
    let files = $("#personaldocsaddmore")[0].files;
    let title = $("#titleaddmore").val();
        let Username = $('#usernametoedit').val();
    if (!files || files.length === 0) {
        alert("Please select at least one file.");
        return;
    }

    let formData = new FormData();
        formData.append("Id", empId);
        formData.append("Username", Username);
    for (let i = 0; i < files.length; i++) {
        formData.append("Files[" + i + "].FileName", files[i].name);
        formData.append("Files[" + i + "].FileTitle", title);
        formData.append("Files[" + i + "].FileBytes", files[i]);
    }

    $.ajax({
        url: '@Url.Action("UploadFiles", "Employees", new { area = "EMS" })',
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function (res) {
            if (res.success) {
                alert("Files uploaded successfully!");
                appendEdittabwithdata(empId, Username);
                $("#addFiles").modal("hide");
            } else {
                alert("Error: " + res.message);
            }
        },
        error: function (xhr, status, error) {
            console.error("Error:", error);
            alert("Error while uploading files.");
        }
    });
}
        function handleEmployeeAction(empId, username, actionType) {
    let confirmMsg = "";
    if (actionType === "inactive") {
        confirmMsg = "Are you sure you want to set " + username + " as Inactive?";
    } else if (actionType === "delete") {
        confirmMsg = "Are you sure you want to permanently delete " + username + " and all related records?";
    }

    if (!confirm(confirmMsg)) {
        return;
    }

    $.ajax({
        url: '@Url.Action("HandleEmployeeAction", "Employees", new { area = "EMS" })',
        type: 'POST',
        contentType: "application/json; charset=utf-8",
        data: JSON.stringify({
            EmpId: empId,
            ActionType: actionType
        }),
        success: function (res) {
            if (res.success) {
                alert(username + " " + (actionType === "inactive" ? "set Inactive" : "deleted") + " successfully!");
                GetEmployeesList();
            } else {
                alert("Error: " + res.message);
            }
        },
        error: function (xhr, status, error) {
            console.error("Error:", error);
            alert("Something went wrong!");
        }
    });
}

// For backward compatibility
function SetInActive(empId, username) {
    handleEmployeeAction(empId, username, "inactive");
}

function Delete(empId, username) {
    handleEmployeeAction(empId, username, "delete");
}

