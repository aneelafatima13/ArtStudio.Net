// 2. Function to Update through AJAX
        function updateProduct() {

    // Collect data using FormData or serialize
    let formData = {
        Id: $("#editProductForm input[name='Id']").val(),
        Name: $("#editProductForm input[name='Name']").val(),
        SKU: $("#editProductForm input[name='SKU']").val(),
        Price: $("#editProductForm input[name='Price']").val(),
        StockQuantity: $("#editProductForm input[name='StockQuantity']").val(),
        DiscountRate: $("#editProductForm input[name='DiscountRate']").val(),
        Description: $("#editProductForm textarea[name='Description']").val(),
        IsAvailable: $("#editIsAvailable").is(':checked'),
        OnSale: $("#editOnSale").is(':checked')
    };

            // 2. Validation
            if (!formData.Price || formData.Price.trim() === '') {
                alert("Price is required");
                return;
            }
            if (!formData.StockQuantity || formData.StockQuantity.trim() === '') {
                alert("Stock Quantity is required");
                return;
            }
    $.ajax({
        url: '@Url.Action("UpdateProduct", "Products", new { area = "Products"})',
        type: 'POST',
        data: formData,
        beforeSend: function () {
            $(".btn-primary").prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Updating...');
        },
        success: function (res) {
            if (res.success) {
                $("#genericModal").modal('hide');
                location.reload(); // Refresh the data view
            } else {
                alert("Error: " + res.message);
            }
        },
        error: function () {
            alert("Connection error.");
        }
    });
        }
        function updateCategory() {
            let productId = $("#productId").val();
            let selectedCategoryIds = [];

            $("#categoriesWrapper select").each(function () {
                let val = $(this).val();
                if (val) {
                    selectedCategoryIds.push(val); // Use push for arrays
                }
            });
    // Collect data using FormData or serialize
    let formData = {
        productId: productId,
        CategoryId: selectedCategoryIds.join(','),
        ExistingMappingIds: $("#existingMappingIds").val(),
    };

    $.ajax({
        url: '@Url.Action("UpdateCategory", "Products", new { area = "Products"})',
        type: 'POST',
        data: formData,
        beforeSend: function () {
            $(".btn-primary").prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Updating...');
        },
        success: function (res) {
            if (res.success) {
                $("#genericModal").modal('hide');
                location.reload(); // Refresh the data view
            } else {
                alert("Error: " + res.message);
            }
        },
        error: function () {
            alert("Connection error.");
        }
    });
        }

                    $(document).on("change", ".category-dropdown", function () {
                debugger;
    let categoryId = $(this).val();
                let level = parseInt($(this).data("level"));

    $(`#categoriesWrapper .category-container`).each(function () {
        if ($(this).data("level") > level) {
            $(this).remove();
        }
    });

    if (categoryId) {
        $.ajax({
            url: '@Url.Action("GetSubCategories", "Categories", new { area = "Products"})',
            type: 'POST',
            data: { parentId: categoryId },
            success: function (res) {
                debugger;
                if (res.length > 0) {
                    let nextLevel = level + 1;

                    // Clone categoriesDiv
                    let $clone = $("#categoriesDiv").clone();
                    $clone.attr("id", `categoriesDiv_${nextLevel}`);
                    $clone.addClass("category-container");
                    $clone.attr("data-level", nextLevel);

                    // Clear old inner content
                    $clone.find("label").remove();
                    $clone.find("select").remove();

                    // Build new dropdown
                    let subSelectId = `SubCategory_${categoryId}_${nextLevel}`;
                    let html = `
                        <label class="form-label" for="${subSelectId}">Select Sub Category</label>
                        <select id="${subSelectId}" class="form-control category-dropdown" data-level="${nextLevel}">
                            <option value="">-- Select Sub Category --</option>
                    `;
                    res.forEach(sc => {
                        html += `<option value="${sc.Id}">${sc.Name}</option>`;
                    });
                    html += `</select>`;

                    $clone.html(html);

                    $("#categoriesWrapper").append($clone);
                }
            }
        });
    }
});

    function loadCategories() {
    $.ajax({
        url: '@Url.Action("GetCategories", "Categories", new { area = "Products"})',
        type: 'POST',
        success: function (res) {
            if (res.success) {
                let $cat = $("#Category");
                $cat.empty().append(`<option value="">-- Select Category --</option>`);

                // res.data is now guaranteed to be the array
                res.data.forEach(c => {
                    $cat.append(`<option value="${c.Id}">${c.Name}</option>`);
                });
            } else {
                console.error(res.message);
            }
        }
    });
}


        async function initializeCategoryTree(categoryBreadcrumbs) {
    if (!categoryBreadcrumbs || categoryBreadcrumbs.length === 0) {
        loadCategories(); // Just load top level if empty
        return;
    }

    // 1. Load the Top Level first
    await new Promise((resolve) => {
        $.ajax({
            url: '@Url.Action("GetCategories", "Categories", new { area = "Products"})',
            type: 'POST',
            success: function (res) {
                if (res.success) {
                    let $cat = $("#Category");
                    $cat.empty().append(`<option value="">-- Select Category --</option>`);
                    res.data.forEach(c => {
                        let selected = (c.Id == categoryBreadcrumbs[0].CategoryId) ? "selected" : "";
                        $cat.append(`<option value="${c.Id}" ${selected}>${c.Name}</option>`);
                    });
                    resolve();
                }
            }
        });
    });

    // 2. Loop through the breadcrumbs to build sub-dropdowns
    // We start from index 0 and build the child for index 1, and so on.
    for (let i = 0; i < categoryBreadcrumbs.length; i++) {
        let currentId = categoryBreadcrumbs[i].CategoryId;
        let nextCategory = categoryBreadcrumbs[i + 1]; // This is what we want to select in the NEXT box

        if (nextCategory) {
            await loadAndSelectSubCategory(currentId, i, nextCategory.CategoryId);
        }
    }
}

function loadAndSelectSubCategory(parentId, currentLevel, nextSelectedId) {
    return new Promise((resolve) => {
        $.ajax({
            url: '@Url.Action("GetSubCategories", "Categories", new { area = "Products"})',
            type: 'POST',
            data: { parentId: parentId },
            success: function (res) {
                if (res.length > 0) {
                    let nextLevel = currentLevel + 1;
                    let subSelectId = `SubCategory_${parentId}_${nextLevel}`;

                    let html = `
                        <div class="category-container mb-2" data-level="${nextLevel}">
                            <label class="form-label small">Sub Category</label>
                            <select id="${subSelectId}" class="form-control category-dropdown" data-level="${nextLevel}">
                                <option value="">-- Select Sub Category --</option>
                                ${res.map(sc => `<option value="${sc.Id}" ${sc.Id == nextSelectedId ? 'selected' : ''}>${sc.Name}</option>`).join('')}
                            </select>
                        </div>`;

                    $("#categoriesWrapper").append(html);
                }
                resolve();
            }
        });
    });
        }

