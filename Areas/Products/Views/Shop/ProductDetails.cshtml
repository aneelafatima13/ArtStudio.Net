
@{
    ViewBag.Title = "ProductDetails";
    Layout = "~/Views/Shared/_FurniLayout.cshtml";
}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <div id="mainCarousel" class="carousel slide border rounded" data-bs-ride="false">
                <div class="carousel-inner" id="carouselInner">
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon bg-dark rounded-circle"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon bg-dark rounded-circle"></span>
                </button>
            </div>

            <div class="mt-3 d-flex gap-2" id="variantThumbnails">
            </div>
        </div>

        <div class="col-md-6">
            <h2 id="pName"></h2>
            <p class="text-muted" id="pSku"></p>
            <hr>
            <h3 class="text-primary" id="pPrice"></h3>
            <div id="pBadges" class="mb-3"></div>
            <p id="pDescription"></p>
            <div id="quntityClock"></div>
            <div class="mt-4">
                <button class="btn btn-lg btn-primary w-100" id="btnAddToCart">
                    <i class="mdi mdi-cart"></i> Add to Cart
                </button>
            </div>
        </div>
    </div>
</div>
<input type="hidden" value="@ViewBag.ProductId" id="productId" />
<input type="hidden" value="@ViewBag.VarientId" id="VarientId" />
@section scripts{
    <script>
        let currentProduct = null;
        let currentSymbol = "Rs."; // Default fallback

        $(document).ready(function () {
            let productId = $("#productId").val();
            if (productId) {
                loadProductDetails(productId);
            }
        });

        function loadProductDetails(id) {
            $.ajax({
                url: '@Url.Action("GetProductDetails", "Shop")',
                type: 'GET',
                data: { id: id },
                success: function (res) {
                    if (res && res.product) {
                        currentProduct = res.product;
                        currentSymbol = res.symbol || "Rs."; // Get dynamic symbol from server

                        // Initial static UI
                        $("#pDescription").text(currentProduct.Description);

                        renderVariantThumbnails();

                        // Check for pre-selected variant from ViewBag
                        let variantId = parseInt($("#VarientId").val());
                        if (variantId > 0) {
                            renderDetails(variantId);
                        } else {
                            renderDetails(null);
                        }
                    }
                },
                error: function() { alert("Error loading product details."); }
            });
        }

        function renderVariantThumbnails() {
            let html = "";

            // Main Product Thumbnail
            let mainPrimaryImg = currentProduct.ProductImages.find(i => i.IsPrimary) || currentProduct.ProductImages[0];
            let mainImgSrc = getImageUrl(mainPrimaryImg ? mainPrimaryImg.ImagePath : '');

            html += `<img src="${mainImgSrc}" class="img-thumbnail variant-thumb active-selection border-primary shadow-sm"
                         style="width:80px; height:80px; cursor:pointer; object-fit:cover;"
                         data-variant-id="0" title="Main Product">`;

            // Variant Thumbnails
            if (currentProduct.varients && currentProduct.varients.length > 0) {
                currentProduct.varients.forEach(v => {
                    let vImg = v.imageslist.find(i => i.IsPrimary) || v.imageslist[0];
                    let vImgSrc = getImageUrl(vImg ? vImg.ImagePath : '');
                    html += `<img src="${vImgSrc}" class="img-thumbnail variant-thumb"
                                 style="width:80px; height:80px; cursor:pointer; object-fit:cover;"
                                 data-variant-id="${v.Id}" title="${v.Colour} - ${v.Size}">`;
                });
            }
            $("#variantThumbnails").html(html);
        }

        // Click event for thumbnails
        $(document).on("click", ".variant-thumb", function () {
            let vId = $(this).data("variant-id");
            renderDetails(vId == 0 ? null : vId, this);
        });

        function renderDetails(variantId, element) {
            // UI Toggle
            if (element) {
                $(".variant-thumb").removeClass("active-selection border-primary shadow-sm");
                $(element).addClass("active-selection border-primary shadow-sm");
            } else if (variantId) {
                // Handle manual call (like initial load)
                $(`.variant-thumb[data-variant-id="${variantId}"]`).addClass("active-selection border-primary shadow-sm");
            }

            let target = variantId ? currentProduct.varients.find(v => v.Id == variantId) : currentProduct;
            let isVariant = !!variantId;
            let stock = target.StockQuantity || 0;

            let badgeHtml = "";
            if (stock <= 0) {
                badgeHtml = '<span class="badge bg-danger">Out of Stock</span>';
            } else if (target.OnSale) {
                let discount = target.DiscountRate > 0 ? target.DiscountRate + "% Off" : "Sale";
                badgeHtml = `<span class="badge bg-primary">Sale ${discount}</span>`;
            }
            $("#pBadges").html(badgeHtml);

            // Update Info
            $("#pName").text(currentProduct.Name + (isVariant ? ` (${target.Colour} - ${target.Size})` : ""));
            $("#pSku").text("SKU: " + (target.SKU || "N/A"));

            // Dynamic Price Logic
            let priceHtml = "";
            if (target.ConvertedDiscountPrice < target.ConvertedPrice) {
                priceHtml = `<span class="text-danger font-weight-bold">${currentSymbol} ${target.ConvertedDiscountPrice}</span>
                             <del class="text-muted ms-2 small">${currentSymbol} ${target.ConvertedPrice}</del>`;
            } else {
                priceHtml = `<span>${currentSymbol} ${target.ConvertedPrice}</span>`;
            }
            $("#pPrice").html(priceHtml);
            if (stock <= 0) {
                $("#carouselInner").css("filter", "grayscale(0.8)");
            } else {
                $("#carouselInner").css("filter", "none");
            }
            // Update Stock & Quantity
            renderQuantitySelector(stock);

            // Update Cart Button
            let cartVarId = isVariant ? target.Id : 'null';
            $("#btnAddToCart").attr("onclick", `addToCart(event, ${currentProduct.Id}, ${cartVarId})`);

            // Update Carousel
            updateCarousel(isVariant ? target.imageslist : currentProduct.ProductImages);
        }

        function renderQuantitySelector(stock) {
            let html = `
        <div class="qty-container d-flex align-items-center mb-4">
            <div class="d-flex align-items-center border rounded ${stock <= 0 ? 'bg-light opacity-50' : ''}">
                <button class="btn btn-light px-3" type="button" onclick="localQtyChange(-1)" ${stock <= 0 ? 'disabled' : ''}>&minus;</button>
                <input type="text" id="txtQty" class="text-center border-0" style="width:50px; background:transparent;" value="${stock > 0 ? 1 : 0}" data-stock="${stock}" readonly>
                <button class="btn btn-light px-3" type="button" onclick="localQtyChange(1)" ${stock <= 0 ? 'disabled' : ''}>&plus;</button>
            </div>
            <small class="ms-3 ${stock > 0 ? 'text-muted' : 'text-danger font-weight-bold'}">
                ${stock > 0 ? '(' + stock + ' available)' : 'Out of Stock'}
            </small>
        </div>`;

            $("#quntityClock").html(html);

            // Update the main Add to Cart button appearance
            const btn = $("#btnAddToCart");
            if (stock <= 0) {
                btn.prop('disabled', true)
                    .addClass('btn-secondary').removeClass('btn-primary')
                    .html('<i class="mdi mdi-cart-off"></i> Out of Stock');
            } else {
                btn.prop('disabled', false)
                    .addClass('btn-primary').removeClass('btn-secondary')
                    .html('<i class="mdi mdi-cart"></i> Add to Cart');
            }
        }
        function localQtyChange(change) {
            const input = $("#txtQty");
            let curr = parseInt(input.val());
            let max = parseInt(input.data('stock'));
            let next = curr + change;
            if (next >= 1 && next <= max) input.val(next);
        }

        function updateCarousel(images) {
            let html = "";
            if (images && images.length > 0) {
                images.forEach((img, i) => {
                    html += `<div class="carousel-item ${i === 0 ? 'active' : ''}">
                                <img src="${getImageUrl(img.ImagePath)}" class="d-block w-100" style="height:450px; object-fit:contain; background:#f8f9fa;">
                             </div>`;
                });
            } else {
                html = `<div class="carousel-item active"><img src="${getImageUrl('')}" class="d-block w-100" style="height:450px; object-fit:contain;"></div>`;
            }
            $("#carouselInner").html(html);
            var carousel = bootstrap.Carousel.getOrCreateInstance(document.querySelector('#mainCarousel'));
            carousel.to(0);
        }

        function getImageUrl(path) {
            if (!path) return '/FurniAssets/images/product-1.png';
            return '@Url.Action("GetImg", "Shop", new { area = "Products"})?path=' + encodeURIComponent(path);
        }

        function addToCart(event, productId, variantId) {
            event.preventDefault();
            const qty = parseInt($("#txtQty").val());
            $.post('@Url.Action("AddToCart", "Cart", new { area = "EndUser" })', { id: productId, quantity: qty, VariantId: variantId }, function (res) {
                if (res.success) {
                    $('#cart-badge').text(res.newCount).show().fadeOut(100).fadeIn(100);
                    alert("Added to cart!");
                } else {
                    alert(res.message);
                }
            });
        }
    </script>
}
